# ============================================================
# SURROGATE GRADIENT
# ============================================================

class SurrogateSpike(torch.autograd.Function):
    scale = 25.0
    @staticmethod
    def forward(ctx, membrane):
        spikes = (membrane > 0).float()
        ctx.save_for_backward(membrane)
        return spikes
    @staticmethod
    def backward(ctx, grad_output):
        membrane, = ctx.saved_tensors
        sigmoid = torch.sigmoid(SurrogateSpike.scale * membrane)
        return grad_output * sigmoid * (1 - sigmoid) * SurrogateSpike.scale

spike_fn = SurrogateSpike.apply

# ============================================================
# FLEXIBLE SNN MODEL
# ============================================================

class FlexibleSNN(nn.Module):
    """
    SNN with configurable architecture for diversity sweep.
    Supports variable hidden size, timesteps, leak rate, threshold, and depth.
    """
    def __init__(self, input_size, hidden_size, output_size, num_steps,
                 beta_init=0.9, threshold=1.0, n_layers=1,
                 noise_std=0.0, dropout_rate=0.0):
        super().__init__()
        self.hidden_size = hidden_size
        self.num_steps = num_steps
        self.threshold = threshold
        self.noise_std = noise_std
        self.n_layers = n_layers

        # Build layers
        self.layers = nn.ModuleList()
        self.bns = nn.ModuleList()
        self.betas = nn.ParameterList()

        # First layer
        self.layers.append(nn.Linear(input_size, hidden_size))
        self.bns.append(nn.BatchNorm1d(hidden_size))
        self.betas.append(nn.Parameter(torch.ones(hidden_size) * beta_init))

        # Additional hidden layers
        for _ in range(n_layers - 1):
            self.layers.append(nn.Linear(hidden_size, hidden_size))
            self.bns.append(nn.BatchNorm1d(hidden_size))
            self.betas.append(nn.Parameter(torch.ones(hidden_size) * beta_init))

        # Output layer
        self.fc_out = nn.Linear(hidden_size, output_size)
        self.dropout = nn.Dropout(dropout_rate) if dropout_rate > 0 else None

    def forward(self, x):
        batch_size = x.size(0)
        device = x.device
        x = x.view(batch_size, -1)

        # Process through each LIF layer
        current_input = x
        total_spikes = 0
        total_neurons = 0

        for layer_idx in range(self.n_layers):
            fc = self.layers[layer_idx]
            bn = self.bns[layer_idx]
            beta = torch.sigmoid(self.betas[layer_idx])

            projected = fc(current_input)
            projected = bn(projected)

            membrane = torch.zeros(batch_size, self.hidden_size, device=device)
            spike_sum = torch.zeros(batch_size, self.hidden_size, device=device)

            for t in range(self.num_steps):
                membrane = beta * membrane + projected
                if self.training and self.noise_std > 0:
                    membrane = membrane + torch.randn_like(membrane) * self.noise_std
                spikes = spike_fn(membrane - self.threshold)
                membrane = membrane * (1 - spikes)
                if self.dropout is not None:
                    spikes = self.dropout(spikes)
                spike_sum += spikes
                total_spikes += spikes.sum().item()
                total_neurons += spikes.numel()

            # Output of this layer feeds into next (or into readout)
            current_input = spike_sum / self.num_steps

        # Readout
        output = self.fc_out(current_input)
        activation_rate = total_spikes / total_neurons if total_neurons > 0 else 0

        return output, activation_rate

    def describe(self):
        return (f"h={self.hidden_size}, T={self.num_steps}, "
                f"β={float(torch.sigmoid(self.betas[0]).mean()):.2f}, "
                f"θ={self.threshold}, L={self.n_layers}")

# ============================================================
# DATA
# ============================================================

def load_data(config):
    transform = transforms.Compose([
        transforms.ToTensor(),
        transforms.Normalize((0.2860,), (0.3530,))
    ])
    train_data = datasets.FashionMNIST('./data', train=True, download=True, transform=transform)
    test_data = datasets.FashionMNIST('./data', train=False, download=True, transform=transform)
    train_loader = DataLoader(train_data, batch_size=config['batch_size'],
                              shuffle=True, num_workers=2, pin_memory=True)
    test_loader = DataLoader(test_data, batch_size=config['batch_size'],
                             shuffle=False, num_workers=2, pin_memory=True)
    return train_loader, test_loader

# ============================================================
# TRAINING & EVALUATION
# ============================================================

def train_snn(model, train_loader, config, name="SNN"):
    optimizer = torch.optim.Adam(model.parameters(), lr=config['lr'])
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, config['epochs'])
    criterion = nn.CrossEntropyLoss()
    device = config['device']
    model = model.to(device)

    for epoch in range(config['epochs']):
        model.train()
        correct = 0
        total = 0
        total_loss = 0

        for data, target in train_loader:
            data, target = data.to(device), target.to(device)
            optimizer.zero_grad()
            output, _ = model(data)
            loss = criterion(output, target)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()
            total_loss += loss.item()
            _, predicted = output.max(1)
            correct += predicted.eq(target).sum().item()
            total += target.size(0)

        scheduler.step()
        if (epoch + 1) % 5 == 0 or epoch == 0:
            print(f"    {name} Epoch {epoch+1}/{config['epochs']}: "
                  f"Loss={total_loss/len(train_loader):.4f}, Acc={100.*correct/total:.1f}%")

    return model


def evaluate_snn(model, test_loader, config):
    device = config['device']
    model.eval()
    model = model.to(device)

    all_logits = []
    all_probs = []
    all_preds = []
    all_targets = []
    all_correct = []
    total_activation = 0
    n_batches = 0

    with torch.no_grad():
        for data, target in test_loader:
            data, target = data.to(device), target.to(device)
            output, act_rate = model(data)
            total_activation += act_rate
            n_batches += 1

            probs = F.softmax(output, dim=1)
            pred = probs.argmax(dim=1)

            all_logits.append(output.cpu())
            all_probs.append(probs.cpu())
            all_preds.append(pred.cpu())
            all_targets.append(target.cpu())
            all_correct.append(pred.eq(target).cpu())

    return {
        'logits': torch.cat(all_logits),
        'probs': torch.cat(all_probs),
        'preds': torch.cat(all_preds),
        'targets': torch.cat(all_targets),
        'correct': torch.cat(all_correct),
        'accuracy': torch.cat(all_correct).float().mean().item(),
        'activation_rate': total_activation / n_batches,
    }

# ============================================================
# ENSEMBLE ANALYSIS WITH TEMPERATURE
# ============================================================

def soft_vote_with_temperature(results_list, targets, temperature=1.0):
    """
    Soft voting with temperature scaling.
    T<1: sharpen (trust first choices more)
    T=1: standard soft vote
    T>1: flatten (amplify second/third choices)
    """
    # Stack logits and apply temperature before softmax
    all_logits = torch.stack([r['logits'] for r in results_list])  # [N, samples, classes]
    all_correct = torch.stack([r['correct'] for r in results_list])

    # Temperature-scaled softmax per network, then average
    tempered_probs = F.softmax(all_logits / temperature, dim=2)
    mean_probs = tempered_probs.mean(dim=0)  # [samples, classes]

    soft_preds = mean_probs.argmax(dim=1)
    soft_correct = soft_preds.eq(targets)
    soft_accuracy = soft_correct.float().mean().item()

    # Emergence: all individuals wrong, soft vote right
    all_wrong = (all_correct.sum(dim=0) == 0)
    emergence_mask = all_wrong & soft_correct
    emergence_count = emergence_mask.sum().item()

    # Per-class emergence
    per_class_emergence = {}
    for c in range(10):
        mask = (targets == c)
        if mask.sum() > 0:
            per_class_emergence[c] = (emergence_mask & mask).sum().item()

    # Analyse emergence examples
    emergence_details = []
    if emergence_count > 0:
        emergence_idx = torch.where(emergence_mask)[0][:15]
        all_preds = torch.stack([r['preds'] for r in results_list])
        for idx in emergence_idx:
            i = idx.item()
            true_label = targets[i].item()
            n_models = len(results_list)
            ranks = []
            probs_true = []
            for m in range(n_models):
                p = tempered_probs[m, i]
                rank = (p > p[true_label]).sum().item() + 1
                ranks.append(rank)
                probs_true.append(float(p[true_label]))
            emergence_details.append({
                'idx': i,
                'true': true_label,
                'soft_pred': soft_preds[i].item(),
                'avg_prob_true': float(mean_probs[i, true_label]),
                'ranks': ranks,
                'probs_true': probs_true,
                'individual_preds': [int(all_preds[m, i]) for m in range(n_models)],
            })

    return {
        'accuracy': soft_accuracy,
        'emergence_count': emergence_count,
        'emergence_rate': emergence_count / len(targets),
        'per_class_emergence': per_class_emergence,
        'emergence_details': emergence_details,
    }


def pairwise_error_correlation(results_list):
    """Compute mean pairwise error correlation across all model pairs."""
    n = len(results_list)
    correlations = []
    for i in range(n):
        for j in range(i + 1, n):
            err_i = (~results_list[i]['correct']).float()
            err_j = (~results_list[j]['correct']).float()
            if err_i.std() > 0 and err_j.std() > 0:
                corr = torch.corrcoef(torch.stack([err_i, err_j]))[0, 1].item()
                correlations.append(corr)
    return np.mean(correlations) if correlations else 0


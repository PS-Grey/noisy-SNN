# MAIN EXPERIMENT
# ============================================================

CLASS_NAMES = ['T-shirt', 'Trouser', 'Pullover', 'Dress', 'Coat',
               'Sandal', 'Shirt', 'Sneaker', 'Bag', 'Boot']

def run_experiment():
    config = CONFIG
    base = config['base']

    print("=" * 65)
    print("SNN ARCHITECTURAL DIVERSITY SWEEP")
    print("Goal: push SNN accuracy ceiling, find diversity that matters")
    print("=" * 65)

    # Load data
    print("\n[1] Loading Fashion-MNIST...")
    train_loader, test_loader = load_data(config)

    # ============================================================
    # TRAIN ALL ARCHITECTURES
    # ============================================================
    all_models = {}
    all_results = {}

    sweep_configs = {}
    for param_name, values in config['sweeps'].items():
        for val in values:
            arch = dict(base)
            arch[param_name] = val
            key = f"{param_name}={val}"
            sweep_configs[key] = {
                'param': param_name,
                'value': val,
                'arch': arch,
            }

    n_total = len(sweep_configs)
    print(f"\n[2] Training {n_total} architectures...")
    print(f"    (4 sweeps × 5 values, baseline appears in each sweep)\n")

    for i, (key, sc) in enumerate(sweep_configs.items()):
        arch = sc['arch']
        print(f"  [{i+1}/{n_total}] {key}")

        # Deterministic seed per architecture (index-based, not hash-based)
        seed = 42 + i * 7919  # prime spacing avoids collisions
        torch.manual_seed(seed)
        np.random.seed(seed)

        model = FlexibleSNN(
            input_size=config['input_size'],
            output_size=config['output_size'],
            hidden_size=arch['hidden_size'],
            num_steps=arch['num_steps'],
            beta_init=arch['beta_init'],
            threshold=arch['threshold'],
            n_layers=arch['n_layers'],
            noise_std=config['noise_std'],
            dropout_rate=config['dropout_rate'],
        )

        model = train_snn(model, train_loader, config, name=key)
        result = evaluate_snn(model, test_loader, config)

        all_models[key] = model
        all_results[key] = result

        print(f"    → Accuracy: {result['accuracy']*100:.1f}%, "
              f"Activation: {result['activation_rate']:.3f}\n")

    # ============================================================
    # [3] INDIVIDUAL RESULTS BY SWEEP
    # ============================================================
    print(f"\n{'='*65}")
    print("INDIVIDUAL ACCURACY BY SWEEP")
    print(f"{'='*65}")

    best_overall_key = None
    best_overall_acc = 0

    for param_name in config['sweeps']:
        values = config['sweeps'][param_name]
        print(f"\n  Sweep: {param_name}")
        print(f"  {'Value':>10} | {'Accuracy':>8} | {'Activation':>10} | {'Errors':>6}")
        print(f"  {'-'*45}")

        for val in values:
            key = f"{param_name}={val}"
            r = all_results[key]
            errors = int((1 - r['accuracy']) * 10000)
            marker = " ←base" if val == base[param_name] else ""
            print(f"  {str(val):>10} | {r['accuracy']*100:>7.1f}% | "
                  f"{r['activation_rate']:>10.3f} | {errors:>6}{marker}")

            if r['accuracy'] > best_overall_acc:
                best_overall_acc = r['accuracy']
                best_overall_key = key

    print(f"\n  BEST SINGLE ARCHITECTURE: {best_overall_key} → {best_overall_acc*100:.1f}%")

    # ============================================================
    # [4] ERROR CORRELATION WITHIN EACH SWEEP
    # ============================================================
    print(f"\n{'='*65}")
    print("ERROR CORRELATION WITHIN SWEEPS")
    print("(lower = more diverse errors = better for ensembles)")
    print(f"{'='*65}")

    sweep_correlations = {}
    for param_name in config['sweeps']:
        values = config['sweeps'][param_name]
        keys = [f"{param_name}={v}" for v in values]
        results = [all_results[k] for k in keys]
        mean_corr = pairwise_error_correlation(results)
        sweep_correlations[param_name] = mean_corr

        # Also compute pairwise matrix
        n = len(results)
        print(f"\n  {param_name}: mean correlation = {mean_corr:.4f}")
        print(f"  {'':>10}", end="")
        for v in values:
            print(f" {str(v):>8}", end="")
        print()
        for i, vi in enumerate(values):
            print(f"  {str(vi):>10}", end="")
            for j, vj in enumerate(values):
                if i == j:
                    print(f" {'—':>8}", end="")
                elif j > i:
                    err_i = (~results[i]['correct']).float()
                    err_j = (~results[j]['correct']).float()
                    if err_i.std() > 0 and err_j.std() > 0:
                        c = torch.corrcoef(torch.stack([err_i, err_j]))[0, 1].item()
                        print(f" {c:>8.3f}", end="")
                    else:
                        print(f" {'N/A':>8}", end="")
                else:
                    print(f" {'':>8}", end="")
            print()

    # Rank sweeps by diversity
    print(f"\n  DIVERSITY RANKING (most diverse first):")
    ranked = sorted(sweep_correlations.items(), key=lambda x: x[1])
    for rank, (param, corr) in enumerate(ranked, 1):
        print(f"    {rank}. {param}: {corr:.4f}")

    most_diverse_param = ranked[0][0]
    print(f"\n  → {most_diverse_param} produces the most diverse errors")

    # ============================================================
    # [5] CROSS-SWEEP CORRELATION (best pair from any sweep)
    # ============================================================
    print(f"\n{'='*65}")
    print("BEST PAIRS ACROSS ALL ARCHITECTURES")
    print(f"{'='*65}")

    all_keys = list(all_results.keys())
    all_pairs = []
    for i, ki in enumerate(all_keys):
        for j, kj in enumerate(all_keys):
            if j <= i:
                continue
            ri = all_results[ki]
            rj = all_results[kj]
            err_i = (~ri['correct']).float()
            err_j = (~rj['correct']).float()
            if err_i.std() > 0 and err_j.std() > 0:
                corr = torch.corrcoef(torch.stack([err_i, err_j]))[0, 1].item()
                # Soft vote accuracy for this pair
                mean_probs = (ri['probs'] + rj['probs']) / 2
                pair_pred = mean_probs.argmax(dim=1)
                pair_acc = pair_pred.eq(ri['targets']).float().mean().item()
                all_pairs.append({
                    'key_i': ki, 'key_j': kj,
                    'corr': corr,
                    'acc_i': ri['accuracy'], 'acc_j': rj['accuracy'],
                    'pair_acc': pair_acc,
                    'acc_gain': pair_acc - max(ri['accuracy'], rj['accuracy']),
                })

    # Sort by pair accuracy (we want the best ensemble, not just lowest correlation)
    all_pairs.sort(key=lambda x: x['pair_acc'], reverse=True)

    print(f"\n  Top 10 pairs by ensemble accuracy:")
    print(f"  {'Pair':<45} {'Corr':>6} {'Ind A':>6} {'Ind B':>6} {'Pair':>6} {'Gain':>6}")
    print(f"  {'-'*80}")
    for p in all_pairs[:10]:
        print(f"  {p['key_i']} + {p['key_j']:<20} "
              f"{p['corr']:>6.3f} {p['acc_i']*100:>5.1f}% {p['acc_j']*100:>5.1f}% "
              f"{p['pair_acc']*100:>5.1f}% {p['acc_gain']*100:>+5.2f}%")

    # Most diverse pairs
    all_pairs_by_div = sorted(all_pairs, key=lambda x: x['corr'])
    print(f"\n  Top 5 pairs by diversity (lowest correlation):")
    print(f"  {'Pair':<45} {'Corr':>6} {'Ind A':>6} {'Ind B':>6} {'Pair':>6}")
    print(f"  {'-'*75}")
    for p in all_pairs_by_div[:5]:
        print(f"  {p['key_i']} + {p['key_j']:<20} "
              f"{p['corr']:>6.3f} {p['acc_i']*100:>5.1f}% {p['acc_j']*100:>5.1f}% "
              f"{p['pair_acc']*100:>5.1f}%")

    # ============================================================
    # [6] TEMPERATURE SWEEP ON BEST PAIRS
    # ============================================================
    print(f"\n{'='*65}")
    print("TEMPERATURE SWEEP — SOFT VOTING")
    print(f"{'='*65}")

    # Test on top-3 accuracy pairs AND top-3 diversity pairs
    test_pairs = []
    seen = set()
    for p in all_pairs[:3]:
        pair_key = tuple(sorted([p['key_i'], p['key_j']]))
        if pair_key not in seen:
            test_pairs.append(p)
            seen.add(pair_key)
    for p in all_pairs_by_div[:3]:
        pair_key = tuple(sorted([p['key_i'], p['key_j']]))
        if pair_key not in seen:
            test_pairs.append(p)
            seen.add(pair_key)

    targets = all_results[all_keys[0]]['targets']

    for p in test_pairs:
        ki, kj = p['key_i'], p['key_j']
        ri, rj = all_results[ki], all_results[kj]
        print(f"\n  Pair: {ki} + {kj}")
        print(f"  Individual: {ri['accuracy']*100:.1f}% / {rj['accuracy']*100:.1f}% | "
              f"Correlation: {p['corr']:.3f}")
        print(f"  {'Temp':>6} | {'Accuracy':>8} | {'Emergence':>9} | {'Emrg %':>7} | Details")
        print(f"  {'-'*60}")

        for temp in config['temperatures']:
            sv = soft_vote_with_temperature([ri, rj], targets, temperature=temp)
            detail = ""
            if sv['emergence_count'] > 0:
                # Show which classes
                active_classes = {c: n for c, n in sv['per_class_emergence'].items() if n > 0}
                class_str = ", ".join(f"{CLASS_NAMES[c]}:{n}" for c, n in active_classes.items())
                detail = f" [{class_str}]"
            print(f"  {temp:>6.2f} | {sv['accuracy']*100:>7.1f}% | "
                  f"{sv['emergence_count']:>9d} | {sv['emergence_rate']*100:>6.2f}% |{detail}")

    # ============================================================
    # [7] BEST ENSEMBLE OF 3-5 FROM ALL ARCHITECTURES
    # ============================================================
    print(f"\n{'='*65}")
    print("BEST ENSEMBLES (N=3 to N=5)")
    print(f"{'='*65}")

    # Find best N=3, N=4, N=5 ensembles by trying top individuals
    top_keys = sorted(all_keys, key=lambda k: all_results[k]['accuracy'], reverse=True)[:10]

    for n_ens in [3, 4, 5]:
        best_ens_acc = 0
        best_ens_combo = None
        best_ens_emergence = 0

        for combo in combinations(top_keys, n_ens):
            combo_results = [all_results[k] for k in combo]
            mean_probs = torch.stack([r['probs'] for r in combo_results]).mean(dim=0)
            ens_pred = mean_probs.argmax(dim=1)
            ens_acc = ens_pred.eq(targets).float().mean().item()

            if ens_acc > best_ens_acc:
                best_ens_acc = ens_acc
                best_ens_combo = combo

        if best_ens_combo:
            combo_results = [all_results[k] for k in best_ens_combo]
            sv = soft_vote_with_temperature(combo_results, targets, temperature=1.0)
            corr = pairwise_error_correlation(combo_results)

            print(f"\n  Best N={n_ens}: {best_ens_acc*100:.1f}% accuracy | "
                  f"Corr: {corr:.3f} | Emergence: {sv['emergence_count']}")
            for k in best_ens_combo:
                print(f"    • {k}: {all_results[k]['accuracy']*100:.1f}%")

            # Temperature sweep on best ensemble
            if n_ens <= 4:
                print(f"    Temperature sweep:")
                for temp in [0.5, 1.0, 2.0, 3.0, 5.0]:
                    sv_t = soft_vote_with_temperature(combo_results, targets, temperature=temp)
                    print(f"      T={temp:.1f}: {sv_t['accuracy']*100:.1f}% | "
                          f"Emergence: {sv_t['emergence_count']}")

    # ============================================================
    # [8] SUMMARY
    # ============================================================
    print(f"\n{'='*65}")
    print("SUMMARY")
    print(f"{'='*65}")

    print(f"""
  ACCURACY CEILING:
    Best single SNN:        {best_overall_key} → {best_overall_acc*100:.1f}%

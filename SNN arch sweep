"""
SNN Architectural Diversity Sweep
=================================
Goal: Push SNN accuracy toward 100% on Fashion-MNIST.
Find which architectural parameter creates the most useful diversity.
Test temperature-scaled soft voting for emergence.

Approach:
  1. Sweep one parameter at a time (hidden_size, num_steps, beta, threshold)
  2. All networks trained with membrane noise (0.4) — proven regulariser
  3. Measure pairwise error correlation within and across sweeps
  4. Test soft voting with temperature sweep for emergence
  5. Find the single best architecture and best ensemble

Run: Google Colab, GPU runtime. ~60-90 minutes.
"""

import torch
import torch.nn as nn
import torch.nn.functional as F
from torch.utils.data import DataLoader
from torchvision import datasets, transforms
import numpy as np
import json

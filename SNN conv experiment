    print("BEST SUBSETS")
    print(f"{'='*65}")

    for n_ens in [2, 3, 4]:
        best_acc = 0
        best_combo = None

        for combo_idx in combinations(range(len(diverse_results)), n_ens):
            combo_r = [diverse_results[i] for i in combo_idx]
            mean_p = torch.stack([r['probs'] for r in combo_r]).mean(dim=0)
            acc = mean_p.argmax(dim=1).eq(targets).float().mean().item()
            if acc > best_acc:
                best_acc = acc
                best_combo = combo_idx

        combo_labels = [diverse_configs[i]['label'] for i in best_combo]
        combo_results = [diverse_results[i] for i in best_combo]
        combo_corr = error_correlation(combo_results)

        print(f"\n  Best N={n_ens}: {best_acc*100:.1f}% | Corr: {combo_corr:.3f}")
        print(f"    Members: {', '.join(combo_labels)}")

        # Temperature sweep on best subset
        print(f"    {'Temp':>6} | {'Acc':>6} | {'Emerge':>7}")
        for temp in [0.5, 1.0, 2.0, 3.0, 5.0]:
            sv = soft_vote_temp(combo_results, targets, temperature=temp)
            print(f"    {temp:>6.1f} | {sv['accuracy']*100:>5.1f}% | {sv['emergence_count']:>7}")

    # ============================================================
    # [7] HARD CORE ANALYSIS
    # ============================================================
    print(f"\n{'='*65}")
    print("HARD CORE ANALYSIS — Images no architecture gets right")
    print(f"{'='*65}")

    # Combine ALL results (noisy, control, ann, all diverse)
    all_results = [noisy_result, ctrl_result] + diverse_results
    all_correct_stack = torch.stack([r['correct'] for r in all_results])

    # Images ALL models get wrong
    n_models_total = len(all_results)
    all_wrong = (all_correct_stack.sum(dim=0) == 0)
    hard_core_count = all_wrong.sum().item()

    # Images at least one model gets right
    some_right = (~all_wrong).sum().item()

    # Per-class hard core
    print(f"\n  Total models compared: {n_models_total} "
          f"({len(diverse_results)} diverse + noisy + control)")
    print(f"  Hard core (ALL wrong): {hard_core_count} "
          f"({hard_core_count/100:.1f}% of test set)")
    print(f"  Recoverable (≥1 right): {some_right}")
    print(f"  → Theoretical ceiling: {(10000-hard_core_count)/100:.1f}%")

    print(f"\n  {'Class':<12} {'Hard core':>10} {'% of class':>10}")
    print(f"  {'-'*35}")
    for c in range(10):
        mask = (targets == c)
        class_hard = (all_wrong & mask).sum().item()
        class_total = mask.sum().item()
        print(f"  {CLASS_NAMES[c]:<12} {class_hard:>10} {class_hard/class_total*100:>9.1f}%")

    # ============================================================
    # [8] SUMMARY
    # ============================================================
    print(f"\n{'='*65}")
    print("SUMMARY")
    print(f"{'='*65}")

    best_idx = max(range(len(diverse_results)),
                   key=lambda i: diverse_results[i]['accuracy'])
    best_individual = diverse_results[best_idx]
    best_label = diverse_configs[best_idx]['label']

    print(f"""
  ACCURACY RESULTS:
    CNN-ANN baseline:           {ann_result['accuracy']*100:.1f}%
    Conv-SNN (noisy, single):   {noisy_result['accuracy']*100:.1f}%
    Conv-SNN (control):         {ctrl_result['accuracy']*100:.1f}%
    Best diverse individual:    {best_individual['accuracy']*100:.1f}% ({best_label})
    Noise regularisation gain:  {(noisy_result['accuracy']-ctrl_result['accuracy'])*100:+.1f}%

  DIVERSITY:
    Error correlation:          {corr:.4f}
    Best emergence count:       {best_emergence_count} (at T={best_emergence_temp})

  EFFICIENCY:
    Activation rate (noisy):    {noisy_result['activation_rate']:.3f}
    Activation rate (control):  {ctrl_result['activation_rate']:.3f}

  HARD CORE:
    Unclassifiable images:      {hard_core_count} ({hard_core_count/100:.1f}%)
    Theoretical ceiling:        {(10000-hard_core_count)/100:.1f}%

  {'Conv-SNN matches CNN-ANN!' if noisy_result['accuracy'] >= ann_result['accuracy'] else f'Gap to CNN-ANN: {gap:.1f}% — room to improve'}
    """)



"""
Convolutional SNN — Accuracy Ceiling + Diversity + Emergence
=============================================================
Removes the spatial handicap of flat SNNs. Convolutional feature
extraction feeds into LIF spiking dynamics.

Targets:
  - Push single SNN accuracy from ~89% toward 95%+
  - Test whether membrane noise regularisation transfers to conv-SNN
  - Test diversity ensemble with temperature-scaled soft voting
  - Measure emergence on the harder architecture

Architecture:
  Conv1(32, 3×3) → LIF → Pool
  Conv2(64, 3×3) → LIF → Pool
  Flatten → FC(hidden_size) → LIF → Output(10)

All spiking layers use LIF neurons with membrane noise.

Run: Google Colab, GPU runtime. ~30-40 minutes.
"""

import torch
import torch.nn as nn
import torch.nn.functional as F
from torch.utils.data import DataLoader
from torchvision import datasets, transforms
import numpy as np
from itertools import combinations
import json

CONFIG = {

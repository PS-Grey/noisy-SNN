    'lr': 1e-3,
    'noise_std': 0.4,
    'dropout_rate': 0.1,

    # Conv architecture
    'conv1_filters': 32,
    'conv2_filters': 64,
    'kernel_size': 3,
    'hidden_size': 256,
    'num_steps': 25,

    # Ensemble
    'n_diverse': 6,

    # Temperature sweep
    'temperatures': [0.25, 0.5, 1.0, 2.0, 3.0, 5.0, 10.0],

    'device': 'cuda' if torch.cuda.is_available() else 'cpu'
}

print(f"Device: {CONFIG['device']}")

# ============================================================
# SURROGATE GRADIENT
# ============================================================

class SurrogateSpike(torch.autograd.Function):
    scale = 25.0
    @staticmethod
    def forward(ctx, membrane):
        spikes = (membrane > 0).float()
        ctx.save_for_backward(membrane)
        return spikes
    @staticmethod
    def backward(ctx, grad_output):
        membrane, = ctx.saved_tensors
        sigmoid = torch.sigmoid(SurrogateSpike.scale * membrane)
        return grad_output * sigmoid * (1 - sigmoid) * SurrogateSpike.scale

spike_fn = SurrogateSpike.apply

# ============================================================
# CONVOLUTIONAL SNN
# ============================================================

class ConvSNN(nn.Module):
    """
    Spiking CNN: conv feature extraction with LIF dynamics at every layer.

    Per timestep:
      Input → Conv1 → BN → LIF → AvgPool
            → Conv2 → BN → LIF → AvgPool
            → Flatten → FC → BN → LIF → Output

    Membrane noise injected at each LIF layer during training.
    """
    def __init__(self, config, noise_std=0.0, dropout_rate=0.0,
                 num_steps=25, beta_init=0.9, hidden_size=256):
        super().__init__()
        self.num_steps = num_steps
        self.noise_std = noise_std
        self.hidden_size = hidden_size

        c1 = config['conv1_filters']
        c2 = config['conv2_filters']
        ks = config['kernel_size']
        pad = ks // 2

        # Conv layers
        self.conv1 = nn.Conv2d(config['input_channels'], c1, ks, padding=pad)
        self.bn_conv1 = nn.BatchNorm2d(c1)
        self.pool1 = nn.AvgPool2d(2)

        self.conv2 = nn.Conv2d(c1, c2, ks, padding=pad)
        self.bn_conv2 = nn.BatchNorm2d(c2)
        self.pool2 = nn.AvgPool2d(2)

        # After 2 pools on 28×28: 7×7 × c2
        flat_size = c2 * 7 * 7

        # FC + LIF layer
        self.fc = nn.Linear(flat_size, hidden_size)
        self.bn_fc = nn.BatchNorm1d(hidden_size)

        # Output
        self.fc_out = nn.Linear(hidden_size, config['output_size'])

        # LIF parameters (learnable per layer)
        self.beta_conv1 = nn.Parameter(torch.ones(c1, 1, 1) * beta_init)
        self.beta_conv2 = nn.Parameter(torch.ones(c2, 1, 1) * beta_init)
        self.beta_fc = nn.Parameter(torch.ones(hidden_size) * beta_init)

        self.threshold = 1.0
        self.dropout = nn.Dropout(dropout_rate) if dropout_rate > 0 else None

    def _lif_step(self, membrane, current, beta, noise_std, spatial=False):
        """One LIF timestep with optional membrane noise."""
        beta_sig = torch.sigmoid(beta)
        membrane = beta_sig * membrane + current

        if self.training and noise_std > 0:
            membrane = membrane + torch.randn_like(membrane) * noise_std

        spikes = spike_fn(membrane - self.threshold)
        membrane = membrane * (1 - spikes)
        return membrane, spikes

    def forward(self, x):
        batch_size = x.size(0)
        device = x.device

        # Compute conv features once (input doesn't change over time)
        conv1_out = self.bn_conv1(self.conv1(x))
        conv1_pooled_shape = self.pool1(torch.zeros_like(conv1_out)).shape

        conv2_in_shape = (batch_size, self.conv2.in_channels,
                          conv1_pooled_shape[2], conv1_pooled_shape[3])

        # Init membrane potentials
        mem_conv1 = torch.zeros_like(conv1_out)
        mem_conv2 = torch.zeros(batch_size, self.conv2.out_channels,
                                conv1_pooled_shape[2], conv1_pooled_shape[3],
                                device=device)
        mem_fc = torch.zeros(batch_size, self.hidden_size, device=device)

        output_sum = torch.zeros(batch_size, 10, device=device)
        total_spikes = 0
        total_neurons = 0

        for t in range(self.num_steps):
            # Conv1 LIF
            mem_conv1, spk_conv1 = self._lif_step(
                mem_conv1, conv1_out, self.beta_conv1, self.noise_std)
            if self.dropout:
                spk_conv1 = self.dropout(spk_conv1)
            pooled1 = self.pool1(spk_conv1)

            # Conv2 LIF
            conv2_current = self.bn_conv2(self.conv2(pooled1))
            mem_conv2, spk_conv2 = self._lif_step(
                mem_conv2, conv2_current, self.beta_conv2, self.noise_std)
            if self.dropout:
                spk_conv2 = self.dropout(spk_conv2)
            pooled2 = self.pool2(spk_conv2)

            # FC LIF
            flat = pooled2.view(batch_size, -1)
            fc_current = self.bn_fc(self.fc(flat))
            mem_fc, spk_fc = self._lif_step(
                mem_fc, fc_current, self.beta_fc, self.noise_std)
            if self.dropout:
                spk_fc = self.dropout(spk_fc)

            # Accumulate output
            output_sum += self.fc_out(spk_fc)

            # Track spikes
            total_spikes += spk_conv1.sum().item() + spk_conv2.sum().item() + spk_fc.sum().item()
            total_neurons += spk_conv1.numel() + spk_conv2.numel() + spk_fc.numel()

        output = output_sum / self.num_steps
        activation_rate = total_spikes / total_neurons if total_neurons > 0 else 0

        return output, activation_rate


class BaselineANN(nn.Module):
    """CNN ANN baseline for fair comparison."""
    def __init__(self, config):
        super().__init__()
        c1 = config['conv1_filters']
        c2 = config['conv2_filters']
        ks = config['kernel_size']
        pad = ks // 2

        self.features = nn.Sequential(
            nn.Conv2d(config['input_channels'], c1, ks, padding=pad),
            nn.BatchNorm2d(c1),
            nn.ReLU(),
            nn.MaxPool2d(2),
            nn.Conv2d(c1, c2, ks, padding=pad),
            nn.BatchNorm2d(c2),
            nn.ReLU(),
            nn.MaxPool2d(2),
        )
        flat_size = c2 * 7 * 7
        self.classifier = nn.Sequential(
            nn.Linear(flat_size, config['hidden_size']),
            nn.BatchNorm1d(config['hidden_size']),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(config['hidden_size'], config['output_size']),
        )

    def forward(self, x):
        x = self.features(x)
        x = x.view(x.size(0), -1)
        return self.classifier(x)

# ============================================================
# DATA — with augmentation for higher accuracy
# ============================================================

def load_data(config):
    train_transform = transforms.Compose([
        transforms.RandomHorizontalFlip(),
        transforms.RandomAffine(degrees=5, translate=(0.05, 0.05)),
        transforms.ToTensor(),
        transforms.Normalize((0.2860,), (0.3530,))
    ])
    test_transform = transforms.Compose([
        transforms.ToTensor(),
        transforms.Normalize((0.2860,), (0.3530,))
    ])

    train_data = datasets.FashionMNIST('./data', train=True, download=True,
                                        transform=train_transform)
    test_data = datasets.FashionMNIST('./data', train=False, download=True,
                                       transform=test_transform)

    train_loader = DataLoader(train_data, batch_size=config['batch_size'],
                              shuffle=True, num_workers=2, pin_memory=True)
    test_loader = DataLoader(test_data, batch_size=config['batch_size'],
                             shuffle=False, num_workers=2, pin_memory=True)
    return train_loader, test_loader

# ============================================================
# TRAINING & EVALUATION
# ============================================================

def train_model(model, train_loader, config, name="model", is_snn=True):
    optimizer = torch.optim.Adam(model.parameters(), lr=config['lr'])
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, config['epochs'])
    criterion = nn.CrossEntropyLoss()
    device = config['device']
    model = model.to(device)

    print(f"\n  {name}:")
    for epoch in range(config['epochs']):
        model.train()
        correct = 0
        total = 0
        total_loss = 0

        for data, target in train_loader:
            data, target = data.to(device), target.to(device)
            optimizer.zero_grad()
            if is_snn:
                output, _ = model(data)
            else:
                output = model(data)
            loss = criterion(output, target)
            loss.backward()
            if is_snn:
                torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()
            total_loss += loss.item()
            _, predicted = output.max(1)
            correct += predicted.eq(target).sum().item()
            total += target.size(0)

        scheduler.step()
        acc = 100. * correct / total
        if (epoch + 1) % 5 == 0 or epoch == 0:
            print(f"    Epoch {epoch+1}/{config['epochs']}: "
                  f"Loss={total_loss/len(train_loader):.4f}, Acc={acc:.1f}%")

    return model


def evaluate_model(model, test_loader, config, is_snn=True):
    device = config['device']
    model.eval()
    model.to(device)

    all_logits = []
    all_probs = []
    all_preds = []
    all_targets = []
    all_correct = []
    total_act = 0
    n_batches = 0

    with torch.no_grad():
        for data, target in test_loader:
            data, target = data.to(device), target.to(device)
            if is_snn:
                output, act = model(data)
                total_act += act
                n_batches += 1
            else:
                output = model(data)

            probs = F.softmax(output, dim=1)
            pred = probs.argmax(dim=1)
            all_logits.append(output.cpu())
            all_probs.append(probs.cpu())
            all_preds.append(pred.cpu())
            all_targets.append(target.cpu())
            all_correct.append(pred.eq(target).cpu())

    return {
        'logits': torch.cat(all_logits),
        'probs': torch.cat(all_probs),
        'preds': torch.cat(all_preds),
        'targets': torch.cat(all_targets),
        'correct': torch.cat(all_correct),
        'accuracy': torch.cat(all_correct).float().mean().item(),
        'activation_rate': total_act / n_batches if n_batches > 0 else 0,
    }

# ============================================================
# SOFT VOTE WITH TEMPERATURE
# ============================================================

def soft_vote_temp(results_list, targets, temperature=1.0):
    all_logits = torch.stack([r['logits'] for r in results_list])
    all_correct = torch.stack([r['correct'] for r in results_list])

    tempered = F.softmax(all_logits / temperature, dim=2)
    mean_probs = tempered.mean(dim=0)
    soft_preds = mean_probs.argmax(dim=1)
    soft_correct = soft_preds.eq(targets)
    soft_acc = soft_correct.float().mean().item()

    # Emergence
    all_wrong = (all_correct.sum(dim=0) == 0)
    emergence_mask = all_wrong & soft_correct
    emergence_count = emergence_mask.sum().item()

    # Per-class
    class_names = ['T-shirt', 'Trouser', 'Pullover', 'Dress', 'Coat',
                   'Sandal', 'Shirt', 'Sneaker', 'Bag', 'Boot']
    per_class = {}
    for c in range(10):
        mask = (targets == c)
        if mask.sum() > 0:
            per_class[class_names[c]] = (emergence_mask & mask).sum().item()

    # Emergence details
    details = []
    if emergence_count > 0:
        all_preds = torch.stack([r['preds'] for r in results_list])
        for idx in torch.where(emergence_mask)[0][:10]:
            i = idx.item()
            n_models = len(results_list)
            ranks = []
            for m in range(n_models):
                p = tempered[m, i]
                rank = (p > p[targets[i]]).sum().item() + 1
                ranks.append(rank)
            details.append({
                'idx': i,
                'true': targets[i].item(),
                'pred': soft_preds[i].item(),
                'avg_p': float(mean_probs[i, targets[i]]),
                'ranks': ranks,
                'ind_preds': [int(all_preds[m, i]) for m in range(n_models)],
            })

    return {
        'accuracy': soft_acc,
        'emergence_count': emergence_count,
        'per_class': per_class,
        'details': details,
    }


def error_correlation(results_list):
    corrs = []
    for i in range(len(results_list)):
        for j in range(i+1, len(results_list)):
            ei = (~results_list[i]['correct']).float()
            ej = (~results_list[j]['correct']).float()
            if ei.std() > 0 and ej.std() > 0:
                c = torch.corrcoef(torch.stack([ei, ej]))[0, 1].item()
                corrs.append(c)
    return np.mean(corrs) if corrs else 0


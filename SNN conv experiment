CLASS_NAMES = ['T-shirt', 'Trouser', 'Pullover', 'Dress', 'Coat',
               'Sandal', 'Shirt', 'Sneaker', 'Bag', 'Boot']

def run_experiment():
    config = CONFIG
    print("=" * 65)
    print("CONVOLUTIONAL SNN — ACCURACY + DIVERSITY + EMERGENCE")
    print("=" * 65)

    print("\n[1] Loading Fashion-MNIST (with augmentation)...")
    train_loader, test_loader = load_data(config)

    # ============================================================
    # [2] TRAIN MODELS
    # ============================================================
    print("\n[2] Training models...")

    # --- Single conv-SNN with noise (main architecture) ---
    torch.manual_seed(42)
    noisy_snn = ConvSNN(config, noise_std=config['noise_std'],
                        dropout_rate=config['dropout_rate'])
    noisy_snn = train_model(noisy_snn, train_loader, config,
                            name="Conv-SNN (noisy)", is_snn=True)
    noisy_result = evaluate_model(noisy_snn, test_loader, config, is_snn=True)
    print(f"    → Test accuracy: {noisy_result['accuracy']*100:.1f}%, "
          f"Activation: {noisy_result['activation_rate']:.3f}")

    # --- Control conv-SNN without noise ---
    torch.manual_seed(42)
    ctrl_snn = ConvSNN(config, noise_std=0.0, dropout_rate=config['dropout_rate'])
    ctrl_snn = train_model(ctrl_snn, train_loader, config,
                           name="Conv-SNN (control)", is_snn=True)
    ctrl_result = evaluate_model(ctrl_snn, test_loader, config, is_snn=True)
    print(f"    → Test accuracy: {ctrl_result['accuracy']*100:.1f}%, "
          f"Activation: {ctrl_result['activation_rate']:.3f}")

    # --- CNN ANN baseline ---
    torch.manual_seed(42)
    ann = BaselineANN(config)
    ann = train_model(ann, train_loader, config, name="CNN-ANN", is_snn=False)
    ann_result = evaluate_model(ann, test_loader, config, is_snn=False)
    print(f"    → Test accuracy: {ann_result['accuracy']*100:.1f}%")

    # --- Diverse conv-SNNs (varied timesteps + noise) ---
    # Based on hypothesis that timesteps create most diversity
    diverse_configs = [
        {'num_steps': 10, 'beta_init': 0.7, 'hidden_size': 256, 'label': 'fast-short'},
        {'num_steps': 15, 'beta_init': 0.8, 'hidden_size': 256, 'label': 'medium'},
        {'num_steps': 25, 'beta_init': 0.9, 'hidden_size': 256, 'label': 'standard'},
        {'num_steps': 40, 'beta_init': 0.95, 'hidden_size': 256, 'label': 'slow-long'},
        {'num_steps': 25, 'beta_init': 0.9, 'hidden_size': 128, 'label': 'small'},
        {'num_steps': 25, 'beta_init': 0.9, 'hidden_size': 384, 'label': 'large'},
    ]

    diverse_models = []
    diverse_results = []

    print(f"\n  Training {len(diverse_configs)} diverse conv-SNNs...")
    for i, dc in enumerate(diverse_configs):
        torch.manual_seed(42 + i * 1000)
        np.random.seed(42 + i * 1000)

        model = ConvSNN(config, noise_std=config['noise_std'],
                        dropout_rate=config['dropout_rate'],
                        num_steps=dc['num_steps'],
                        beta_init=dc['beta_init'],
                        hidden_size=dc['hidden_size'])
        model = train_model(model, train_loader, config,
                            name=f"Diverse-{dc['label']}", is_snn=True)
        result = evaluate_model(model, test_loader, config, is_snn=True)
        diverse_models.append(model)
        diverse_results.append(result)
        print(f"    → {dc['label']}: {result['accuracy']*100:.1f}%, "
              f"Act: {result['activation_rate']:.3f}")

    # ============================================================
    # [3] RESULTS
    # ============================================================
    targets = noisy_result['targets']

    print(f"\n{'='*65}")
    print("NOISE REGULARISATION — CONV-SNN")
    print(f"{'='*65}")
    print(f"  Control (no noise): {ctrl_result['accuracy']*100:.1f}%, "
          f"Activation: {ctrl_result['activation_rate']:.3f}")
    print(f"  Noisy:              {noisy_result['accuracy']*100:.1f}%, "
          f"Activation: {noisy_result['activation_rate']:.3f}")
    print(f"  Delta:              {(noisy_result['accuracy']-ctrl_result['accuracy'])*100:+.1f}% accuracy, "
          f"{noisy_result['activation_rate']-ctrl_result['activation_rate']:+.3f} activation")
    print(f"  CNN-ANN baseline:   {ann_result['accuracy']*100:.1f}%")

    gap = (ann_result['accuracy'] - noisy_result['accuracy']) * 100
    if gap <= 0:
        print(f"\n  ✓ Conv-SNN MATCHES OR BEATS CNN-ANN!")
    else:
        print(f"\n  Gap to CNN-ANN: {gap:.1f}%")

    # ============================================================
    # [4] DIVERSITY ANALYSIS
    # ============================================================
    print(f"\n{'='*65}")
    print("DIVERSE CONV-SNN ENSEMBLE")
    print(f"{'='*65}")

    print(f"\n  Individual results:")
    print(f"  {'Label':<15} {'Steps':>5} {'Beta':>5} {'Hidden':>6} {'Acc':>7} {'Act':>6}")
    print(f"  {'-'*50}")
    for dc, r in zip(diverse_configs, diverse_results):
        print(f"  {dc['label']:<15} {dc['num_steps']:>5} {dc['beta_init']:>5.2f} "
              f"{dc['hidden_size']:>6} {r['accuracy']*100:>6.1f}% {r['activation_rate']:>5.3f}")

    # Error correlation
    corr = error_correlation(diverse_results)
    print(f"\n  Mean error correlation: {corr:.4f}")

    # Pairwise
    print(f"\n  Pairwise correlations:")
    labels = [dc['label'] for dc in diverse_configs]
    print(f"  {'':>15}", end="")
    for l in labels:
        print(f" {l[:8]:>8}", end="")
    print()
    for i, li in enumerate(labels):
        print(f"  {li:<15}", end="")
        for j, lj in enumerate(labels):
            if i == j:
                print(f" {'—':>8}", end="")
            elif j > i:
                ei = (~diverse_results[i]['correct']).float()
                ej = (~diverse_results[j]['correct']).float()
                c = torch.corrcoef(torch.stack([ei, ej]))[0, 1].item()
                print(f" {c:>8.3f}", end="")
            else:
                print(f" {'':>8}", end="")
        print()

    # ============================================================
    # [5] TEMPERATURE SWEEP
    # ============================================================
    print(f"\n{'='*65}")
    print("TEMPERATURE SWEEP — ALL DIVERSE CONV-SNNs")
    print(f"{'='*65}")

    print(f"\n  N={len(diverse_results)} networks")
    print(f"  {'Temp':>6} | {'Accuracy':>8} | {'Emergence':>9} | {'Details'}")
    print(f"  {'-'*60}")

    best_emergence_temp = 1.0
    best_emergence_count = 0

    for temp in config['temperatures']:
        sv = soft_vote_temp(diverse_results, targets, temperature=temp)
        active = {k: v for k, v in sv['per_class'].items() if v > 0}
        detail = ", ".join(f"{k}:{v}" for k, v in active.items()) if active else ""
        print(f"  {temp:>6.2f} | {sv['accuracy']*100:>7.1f}% | "
              f"{sv['emergence_count']:>9d} | {detail}")

        if sv['emergence_count'] > best_emergence_count:
            best_emergence_count = sv['emergence_count']
            best_emergence_temp = temp

    # Show emergence examples at best temperature
    if best_emergence_count > 0:
        sv = soft_vote_temp(diverse_results, targets, temperature=best_emergence_temp)
        print(f"\n  Best emergence at T={best_emergence_temp}: {best_emergence_count} cases")
        if sv['details']:
            print(f"  {'Idx':>5} | {'True':>12} | {'Pred':>12} | {'Avg P':>6} | "
                  f"{'Ranks':>25} | Individual preds")
            print(f"  {'-'*85}")
            for d in sv['details'][:10]:
                true_name = CLASS_NAMES[d['true']]
                pred_name = CLASS_NAMES[d['pred']]
                print(f"  {d['idx']:>5} | {true_name:>12} | {pred_name:>12} | "
                      f"{d['avg_p']:>5.3f} | {str(d['ranks']):>25} | {d['ind_preds']}")

    # ============================================================
    # [6] BEST PAIRS AND TRIOS
    # ============================================================

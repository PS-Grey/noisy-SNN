# ============================================================
# MODELS (same as emergence experiment)
# ============================================================

class SurrogateSpike(torch.autograd.Function):
    scale = 25.0
    @staticmethod
    def forward(ctx, membrane):
        spikes = (membrane > 0).float()
        ctx.save_for_backward(membrane)
        return spikes
    @staticmethod
    def backward(ctx, grad_output):
        membrane, = ctx.saved_tensors
        sigmoid = torch.sigmoid(SurrogateSpike.scale * membrane)
        return grad_output * sigmoid * (1 - sigmoid) * SurrogateSpike.scale

spike_fn = SurrogateSpike.apply


class DiverseSNN(nn.Module):
    def __init__(self, config, noise_std=0.0, dropout_rate=0.0):
        super().__init__()
        self.config = config
        self.noise_std = noise_std
        self.dropout_rate = dropout_rate
        self.num_steps = config['num_steps']
        self.fc1 = nn.Linear(config['input_size'], config['hidden_size'])
        self.bn1 = nn.BatchNorm1d(config['hidden_size'])
        self.fc2 = nn.Linear(config['hidden_size'], config['output_size'])
        self.beta = nn.Parameter(torch.ones(config['hidden_size']) * 0.9)
        self.threshold = 1.0
        self.dropout = nn.Dropout(dropout_rate) if dropout_rate > 0 else None

    def forward(self, x):
        batch_size = x.size(0)
        device = x.device
        x = x.view(batch_size, -1)
        input_current = self.fc1(x)
        input_current = self.bn1(input_current)
        membrane = torch.zeros(batch_size, self.config['hidden_size'], device=device)
        output_sum = torch.zeros(batch_size, self.config['output_size'], device=device)
        beta = torch.sigmoid(self.beta)
        spikes_total = 0
        active_total = 0

        for t in range(self.num_steps):
            membrane = beta * membrane + input_current
            if self.training and self.noise_std > 0:
                membrane = membrane + torch.randn_like(membrane) * self.noise_std
            spikes = spike_fn(membrane - self.threshold)
            membrane = membrane * (1 - spikes)
            if self.dropout is not None:
                spikes = self.dropout(spikes)
            spikes_total += spikes.sum().item()
            active_total += spikes.numel()
            output_sum += self.fc2(spikes)

        output = output_sum / self.num_steps
        activation_rate = spikes_total / active_total if active_total > 0 else 0
        return output, activation_rate


class BaselineANN(nn.Module):
    def __init__(self, config):
        super().__init__()
        self.net = nn.Sequential(
            nn.Flatten(),
            nn.Linear(config['input_size'], config['ann_hidden']),
            nn.BatchNorm1d(config['ann_hidden']),
            nn.ReLU(),
            nn.Dropout(0.2),
            nn.Linear(config['ann_hidden'], config['ann_hidden']),
            nn.BatchNorm1d(config['ann_hidden']),
            nn.ReLU(),
            nn.Dropout(0.2),
            nn.Linear(config['ann_hidden'], config['output_size'])
        )
    def forward(self, x):
        return self.net(x)


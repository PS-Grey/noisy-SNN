def load_data(config):
    transform = transforms.Compose([
        transforms.ToTensor(),
        transforms.Normalize((0.2860,), (0.3530,))
    ])
    train_data = datasets.FashionMNIST('./data', train=True, download=True, transform=transform)
    test_data = datasets.FashionMNIST('./data', train=False, download=True, transform=transform)
    train_loader = DataLoader(train_data, batch_size=config['batch_size'],
                              shuffle=True, num_workers=2, pin_memory=True)
    test_loader = DataLoader(test_data, batch_size=config['batch_size'],
                             shuffle=False, num_workers=2, pin_memory=True)
    # OOD
    ood_data = datasets.MNIST('./data', train=False, download=True, transform=transform)
    ood_loader = DataLoader(ood_data, batch_size=config['batch_size'],
                            shuffle=False, num_workers=2, pin_memory=True)
    return train_loader, test_loader, ood_loader

# ============================================================
# TRAINING
# ============================================================

def train_model(model, train_loader, config, name="model", is_snn=True):
    optimizer = torch.optim.Adam(model.parameters(), lr=config['lr'])
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, config['epochs'])
    criterion = nn.CrossEntropyLoss()
    device = config['device']
    model = model.to(device)

    print(f"\n  {name}: Training...")
    for epoch in range(config['epochs']):
        model.train()
        correct = 0
        total = 0
        total_loss = 0

        for data, target in train_loader:
            data, target = data.to(device), target.to(device)
            optimizer.zero_grad()
            if is_snn:
                output, _ = model(data)
            else:
                output = model(data)
            loss = criterion(output, target)
            loss.backward()
            if is_snn:
                torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()
            total_loss += loss.item()
            _, predicted = output.max(1)
            correct += predicted.eq(target).sum().item()
            total += target.size(0)

        scheduler.step()
        if (epoch + 1) % 5 == 0 or epoch == 0:
            print(f"    Epoch {epoch+1}/{config['epochs']}: "
                  f"Loss={total_loss/len(train_loader):.4f}, Acc={100.*correct/total:.1f}%")

    return model

# ============================================================
# TRIAGE SYSTEM
# ============================================================

def run_triage(snn_a, snn_b, ann, test_loader, config, confidence_threshold=0.0):
    """
    Two-SNN triage with ANN escalation.

    For each input:
      1. Both SNNs produce probability distributions
      2. Soft vote = average of both distributions
      3. Check agreement (same top-1 prediction) AND confidence (soft vote max prob)
      4. If agree AND confident → return soft vote (cheap)
      5. If disagree OR not confident → escalate to ANN (expensive)

    Returns per-sample results for detailed analysis.
    """
    device = config['device']
    snn_a.eval()
    snn_b.eval()
    ann.eval()

    all_results = []

    with torch.no_grad():
        for data, target in test_loader:
            data, target = data.to(device), target.to(device)
            batch_size = data.size(0)

            # Both SNNs
            out_a, act_a = snn_a(data)
            out_b, act_b = snn_b(data)
            probs_a = F.softmax(out_a, dim=1)
            probs_b = F.softmax(out_b, dim=1)

            # Individual predictions
            pred_a = probs_a.argmax(dim=1)
            pred_b = probs_b.argmax(dim=1)

            # Soft vote
            soft_probs = (probs_a + probs_b) / 2
            soft_pred = soft_probs.argmax(dim=1)
            soft_conf = soft_probs.max(dim=1)[0]

            # Agreement
            agree = pred_a.eq(pred_b)

            # Triage decision: agree AND confident
            use_snn = agree & (soft_conf >= confidence_threshold)

            # ANN for escalated inputs
            ann_out = ann(data)
            ann_probs = F.softmax(ann_out, dim=1)
            ann_pred = ann_probs.argmax(dim=1)

            # Final prediction: SNN where trusted, ANN where escalated
            final_pred = torch.where(use_snn, soft_pred, ann_pred)

            for i in range(batch_size):
                all_results.append({
                    'target': target[i].item(),
                    'pred_a': pred_a[i].item(),
                    'pred_b': pred_b[i].item(),
                    'soft_pred': soft_pred[i].item(),
                    'soft_conf': soft_conf[i].item(),
                    'ann_pred': ann_pred[i].item(),
                    'final_pred': final_pred[i].item(),
                    'agree': agree[i].item(),
                    'used_snn': use_snn[i].item(),
                    'correct_soft': soft_pred[i].item() == target[i].item(),
                    'correct_ann': ann_pred[i].item() == target[i].item(),
                    'correct_final': final_pred[i].item() == target[i].item(),
                    'correct_a': pred_a[i].item() == target[i].item(),
                    'correct_b': pred_b[i].item() == target[i].item(),
                    'act_a': act_a,
                    'act_b': act_b,
                })

    return all_results


def analyse_triage(results, snn_cost=0.30):
    """Analyse triage system performance and cost."""
    n = len(results)

    # Accuracy
    acc_a = sum(r['correct_a'] for r in results) / n
    acc_b = sum(r['correct_b'] for r in results) / n
    acc_soft = sum(r['correct_soft'] for r in results) / n
    acc_ann = sum(r['correct_ann'] for r in results) / n
    acc_final = sum(r['correct_final'] for r in results) / n

    # Routing
    snn_rate = sum(r['used_snn'] for r in results) / n
    ann_rate = 1 - snn_rate
    agree_rate = sum(r['agree'] for r in results) / n

    # Cost (2 SNNs always run + ANN on escalated)
    cost = 2 * snn_cost + ann_rate * 1.0

    # Accuracy breakdown by route
    snn_samples = [r for r in results if r['used_snn']]
    ann_samples = [r for r in results if not r['used_snn']]

    acc_snn_route = sum(r['correct_final'] for r in snn_samples) / len(snn_samples) if snn_samples else 0
    acc_ann_route = sum(r['correct_final'] for r in ann_samples) / len(ann_samples) if ann_samples else 0

    # Where did triage help vs hurt?
    # Cases where SNN was right but we escalated to ANN (unnecessary escalation)
    unnecessary_escalation = sum(1 for r in ann_samples if r['correct_soft']) if ann_samples else 0
    # Cases where SNN was wrong and ANN fixed it (successful escalation)
    successful_escalation = sum(1 for r in ann_samples
                                if r['correct_ann'] and not r['correct_soft']) if ann_samples else 0
    # Cases where SNN was wrong and ANN also wrong (failed escalation)
    failed_escalation = sum(1 for r in ann_samples
                            if not r['correct_ann'] and not r['correct_soft']) if ann_samples else 0
    # Cases where SNN was right but ANN was wrong (harmful escalation)
    harmful_escalation = sum(1 for r in ann_samples
                             if not r['correct_ann'] and r['correct_soft']) if ann_samples else 0

    # Per-class routing
    per_class = {}
    for c in range(10):
        class_samples = [r for r in results if r['target'] == c]
        if class_samples:
            per_class[c] = {
                'n': len(class_samples),
                'snn_rate': sum(r['used_snn'] for r in class_samples) / len(class_samples),
                'acc_final': sum(r['correct_final'] for r in class_samples) / len(class_samples),
                'acc_soft': sum(r['correct_soft'] for r in class_samples) / len(class_samples),
                'acc_ann': sum(r['correct_ann'] for r in class_samples) / len(class_samples),
            }

    return {
        'acc_snn_a': acc_a,
        'acc_snn_b': acc_b,
        'acc_soft_vote': acc_soft,
        'acc_ann': acc_ann,
        'acc_triage': acc_final,
        'snn_rate': snn_rate,
        'ann_rate': ann_rate,
        'agree_rate': agree_rate,
        'cost': cost,
        'acc_snn_route': acc_snn_route,
        'acc_ann_route': acc_ann_route,
        'unnecessary_escalation': unnecessary_escalation,
        'successful_escalation': successful_escalation,
        'failed_escalation': failed_escalation,
        'harmful_escalation': harmful_escalation,
        'per_class': per_class,
        'n_samples': n,
    }

# ============================================================
# SINGLE SNN TRIAGE (baseline from original research)
# ============================================================

def run_single_snn_triage(snn, ann, test_loader, config, confidence_threshold=0.7):
    """Original single-SNN triage for comparison."""
    device = config['device']
    snn.eval()
    ann.eval()

    results = []
    with torch.no_grad():
        for data, target in test_loader:
            data, target = data.to(device), target.to(device)

            out_snn, act = snn(data)
            probs_snn = F.softmax(out_snn, dim=1)
            conf_snn = probs_snn.max(dim=1)[0]
            pred_snn = probs_snn.argmax(dim=1)

            use_snn = conf_snn >= confidence_threshold

            ann_out = ann(data)
            pred_ann = ann_out.argmax(dim=1)

            final_pred = torch.where(use_snn, pred_snn, pred_ann)

            for i in range(data.size(0)):
                results.append({
                    'target': target[i].item(),
                    'used_snn': use_snn[i].item(),
                    'correct_final': final_pred[i].item() == target[i].item(),
                    'correct_snn': pred_snn[i].item() == target[i].item(),
                    'correct_ann': pred_ann[i].item() == target[i].item(),
                })

    n = len(results)
    snn_rate = sum(r['used_snn'] for r in results) / n
    return {
        'acc_triage': sum(r['correct_final'] for r in results) / n,
        'acc_snn': sum(r['correct_snn'] for r in results) / n,
        'acc_ann': sum(r['correct_ann'] for r in results) / n,
        'snn_rate': snn_rate,
        'cost': 0.30 + (1 - snn_rate) * 1.0,
    }


# ============================================================
# SURROGATE GRADIENT
# ============================================================

class SurrogateSpike(torch.autograd.Function):
    """Straight-through estimator with sigmoid surrogate gradient."""
    scale = 25.0

    @staticmethod
    def forward(ctx, membrane):
        spikes = (membrane > 0).float()
        ctx.save_for_backward(membrane)
        return spikes

    @staticmethod
    def backward(ctx, grad_output):
        membrane, = ctx.saved_tensors
        sigmoid = torch.sigmoid(SurrogateSpike.scale * membrane)
        return grad_output * sigmoid * (1 - sigmoid) * SurrogateSpike.scale

spike_fn = SurrogateSpike.apply

# ============================================================
# SNN MODEL (LIF neurons with batch norm)
# ============================================================

class DiverseSNN(nn.Module):
    """
    Leaky Integrate-and-Fire SNN with noise injection for
    developmental stochasticity.

    Diversity sources (between networks):
      1. Different random weight initialisation (via different seeds)
      2. Transient membrane noise during training — different noise at
         each timestep perturbs which neurons fire, altering gradient
         signals and shaping each network's learning trajectory differently
      3. Stochastic neuron silencing (dropout on spikes)

    The noise is TRANSIENT (per-timestep, not accumulated) so weights
    stay clean for gradient descent. Diversity emerges because different
    noise histories during training produce different learned representations.
    """
    def __init__(self, config, noise_std=0.0, dropout_rate=0.0):
        super().__init__()
        self.config = config
        self.noise_std = noise_std
        self.dropout_rate = dropout_rate
        self.num_steps = config['num_steps']

        # Layers
        self.fc1 = nn.Linear(config['input_size'], config['hidden_size'])
        self.bn1 = nn.BatchNorm1d(config['hidden_size'])
        self.fc2 = nn.Linear(config['hidden_size'], config['output_size'])

        # LIF parameters (learnable)
        self.beta = nn.Parameter(torch.ones(config['hidden_size']) * 0.9)
        self.threshold = 1.0

        # Dropout for stochastic silencing
        self.dropout = nn.Dropout(dropout_rate) if dropout_rate > 0 else None

    def forward(self, x):
        batch_size = x.size(0)
        device = x.device

        # Flatten
        x = x.view(batch_size, -1)

        # Encode as constant current over timesteps
        input_current = self.fc1(x)
        input_current = self.bn1(input_current)

        # LIF dynamics
        membrane = torch.zeros(batch_size, self.config['hidden_size'], device=device)
        spike_sum = torch.zeros(batch_size, self.config['hidden_size'], device=device)
        output_sum = torch.zeros(batch_size, self.config['output_size'], device=device)

        beta = torch.sigmoid(self.beta)  # keep in [0, 1]

        spikes_total = 0
        active_total = 0

        for t in range(self.num_steps):
            # Leaky integration
            membrane = beta * membrane + input_current

            # Inject transient membrane noise during training
            # (biological analogue: neural noise from thermal/quantum
            #  fluctuations — different each timestep, not accumulated)
            if self.training and self.noise_std > 0:
                membrane_noise = torch.randn_like(membrane) * self.noise_std
                membrane = membrane + membrane_noise

            # Spike generation
            spikes = spike_fn(membrane - self.threshold)

            # Reset after spike
            membrane = membrane * (1 - spikes)

            # Apply stochastic silencing (neuron-level dropout)
            if self.dropout is not None:
                spikes = self.dropout(spikes)

            spike_sum += spikes

            # Track activation
            spikes_total += spikes.sum().item()
            active_total += spikes.numel()

            # Accumulate output
            output_sum += self.fc2(spikes)

        # Average over timesteps
        output = output_sum / self.num_steps
        activation_rate = spikes_total / active_total if active_total > 0 else 0

        return output, spike_sum, activation_rate


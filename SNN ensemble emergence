def run_experiment():
    """Run the full ensemble emergence experiment."""
    config = CONFIG
    print("=" * 60)
    print("SNN ENSEMBLE EMERGENCE EXPERIMENT")
    print("=" * 60)
    print(f"\nConfig: {json.dumps({k: v for k, v in config.items() if k != 'device'}, indent=2)}")

    # Load data
    print("\n[1/7] Loading data...")
    train_loader, test_loader, ood_loader = load_data(config)
    print(f"  Train: 60,000 (full Fashion-MNIST), Test: 10,000, OOD: 10,000 (MNIST digits)")

    # Train diverse SNNs (WITH noise)
    print(f"\n[2/7] Training {config['max_ensemble']} NOISY SNNs (noise_std={config['synaptic_noise_std']})...")
    snn_models = []
    for i in range(config['max_ensemble']):
        torch.manual_seed(42 + i * 1000)
        np.random.seed(42 + i * 1000)

        model = DiverseSNN(
            config,
            noise_std=config['synaptic_noise_std'],
            dropout_rate=config['dropout_rate']
        )
        model = train_snn(model, train_loader, config, snn_id=i)
        snn_models.append(model)

    # Train control SNNs (dropout but NO noise — isolates membrane noise effect)
    n_control = config['max_ensemble']  # match noisy count for full N comparison
    print(f"\n[3/7] Training {n_control} CONTROL SNNs (dropout=0.1, noise_std=0, same seeds)...")
    control_models = []
    for i in range(n_control):
        torch.manual_seed(42 + i * 1000)  # SAME seeds as noisy SNNs
        np.random.seed(42 + i * 1000)

        model = DiverseSNN(
            config,
            noise_std=0.0,                    # NO membrane noise
            dropout_rate=config['dropout_rate'] # SAME dropout as noisy (0.1)
        )
        model = train_snn(model, train_loader, config, snn_id=f"ctrl-{i}")
        control_models.append(model)

    # Train ANN baseline
    print(f"\n[4/7] Training ANN baseline...")
    torch.manual_seed(42)
    ann_model = BaselineANN(config)
    ann_model = train_ann(ann_model, train_loader, config)

    # Evaluate all models
    print(f"\n[5/7] Evaluating...")

    # Noisy SNNs on test data
    snn_results = []
    for i, model in enumerate(snn_models):
        result = evaluate_single(model, test_loader, config, is_snn=True)
        snn_results.append(result)
        print(f"  SNN-{i} (noisy):  Accuracy={result['accuracy']*100:.1f}%, "
              f"Activation={result['activation_rate']:.3f}")

    # Control SNNs on test data
    control_results = []
    for i, model in enumerate(control_models):
        result = evaluate_single(model, test_loader, config, is_snn=True)
        control_results.append(result)
        print(f"  SNN-ctrl-{i}:     Accuracy={result['accuracy']*100:.1f}%, "
              f"Activation={result['activation_rate']:.3f}")

    # SNNs on OOD data
    ood_results = []
    for i, model in enumerate(snn_models):
        result = evaluate_single(model, ood_loader, config, is_snn=True)
        ood_results.append(result)

    # Control on OOD data
    control_ood_results = []
    for i, model in enumerate(control_models):
        result = evaluate_single(model, ood_loader, config, is_snn=True)
        control_ood_results.append(result)

    # ANN on test data
    ann_result = evaluate_single(ann_model, test_loader, config, is_snn=False)
    print(f"  ANN:              Accuracy={ann_result['accuracy']*100:.1f}%")

    # ============================================================
    # CONTROL vs NOISY COMPARISON (across all N values)
    # ============================================================
    print(f"\n[6/7] Control vs Noisy comparison...")
    targets = snn_results[0]['targets']

    print(f"\n{'='*60}")
    print("CONTROL vs NOISY — Error Correlation by N")
    print(f"{'='*60}")
    print(f"  {'N':>3} | {'Control':>10} | {'Noisy':>10} | {'Delta':>10} | {'Gap widens?':>12}")
    print(f"  {'-'*55}")

    prev_delta = None
    for n in config['ensemble_sizes']:
        if n > len(control_results) or n > len(snn_results):
            continue
        ctrl = analyse_ensemble(control_results, targets, ensemble_size=n)
        noisy = analyse_ensemble(snn_results, targets, ensemble_size=n)
        delta = noisy['mean_error_correlation'] - ctrl['mean_error_correlation']
        widens = ""
        if prev_delta is not None:
            widens = "yes" if delta < prev_delta else "no"
        prev_delta = delta
        print(f"  {n:>3} | {ctrl['mean_error_correlation']:>10.4f} | "
              f"{noisy['mean_error_correlation']:>10.4f} | {delta:>+10.4f} | {widens:>12}")

    # Detailed comparison at N=10 (full ensemble)
    n_full = min(config['max_ensemble'], len(control_results), len(snn_results))
    control_ens = analyse_ensemble(control_results, targets, ensemble_size=n_full)
    noisy_ens = analyse_ensemble(snn_results, targets, ensemble_size=n_full)

    print(f"\n{'='*60}")
    print(f"CONTROL vs NOISY — Detail at N={n_full}")
    print(f"{'='*60}")
    print(f"  {'Metric':<30} {'Control':>10} {'Noisy':>10} {'Delta':>10}")
    print(f"  {'-'*60}")
    print(f"  {'Mean individual accuracy':<30} "
          f"{control_ens['mean_individual_accuracy']*100:>9.1f}% "
          f"{noisy_ens['mean_individual_accuracy']*100:>9.1f}% "
          f"{(noisy_ens['mean_individual_accuracy']-control_ens['mean_individual_accuracy'])*100:>+9.1f}%")
    print(f"  {'Ensemble accuracy':<30} "
          f"{control_ens['ensemble_accuracy']*100:>9.1f}% "
          f"{noisy_ens['ensemble_accuracy']*100:>9.1f}% "
          f"{(noisy_ens['ensemble_accuracy']-control_ens['ensemble_accuracy'])*100:>+9.1f}%")
    print(f"  {'Error correlation':<30} "
          f"{control_ens['mean_error_correlation']:>10.4f} "
          f"{noisy_ens['mean_error_correlation']:>10.4f} "
          f"{noisy_ens['mean_error_correlation']-control_ens['mean_error_correlation']:>+10.4f}")
    print(f"  {'Emergence count':<30} "
          f"{control_ens['emergence_count']:>10d} "
          f"{noisy_ens['emergence_count']:>10d}")
    print(f"  {'Split vote rate':<30} "
          f"{control_ens['split_vote']*100:>9.1f}% "
          f"{noisy_ens['split_vote']*100:>9.1f}%")

    # Activation rates
    ctrl_act = np.mean([r.get('activation_rate', 0) for r in control_results])
    noisy_act = np.mean([r.get('activation_rate', 0) for r in snn_results])
    print(f"  {'Mean activation rate':<30} "
          f"{ctrl_act:>10.3f} "
          f"{noisy_act:>10.3f} "
          f"{noisy_act-ctrl_act:>+10.3f}")
    print(f"  {'Cost per SNN (relative)':<30} "
          f"{ctrl_act:>10.3f} "
          f"{noisy_act:>10.3f}")

    # OOD comparison
    control_ood = analyse_ood_detection(control_results, control_ood_results, ensemble_size=n_full)
    noisy_ood = analyse_ood_detection(snn_results, ood_results, ensemble_size=n_full)

    print(f"\n  {'OOD detection rate':<30} "
          f"{control_ood['ood_detection_rate']*100:>9.1f}% "
          f"{noisy_ood['ood_detection_rate']*100:>9.1f}%")
    print(f"  {'OOD false alarm rate':<30} "
          f"{control_ood['in_dist_false_alarm_rate']*100:>9.1f}% "
          f"{noisy_ood['in_dist_false_alarm_rate']*100:>9.1f}%")

    # BatchNorm suppression check
    noisy_acc = noisy_ens['mean_individual_accuracy'] * 100
    if noisy_acc > 94:
        print(f"\n  ⚠ WARNING: Noisy SNN accuracy={noisy_acc:.1f}% (>94%). "
              f"BatchNorm may be suppressing noise. Consider disabling BN or increasing noise.")
    elif noisy_acc < 85:
        print(f"\n  ⚠ WARNING: Noisy SNN accuracy={noisy_acc:.1f}% (<85%). "
              f"Noise may be too aggressive. Consider reducing to 0.25.")
    else:
        print(f"\n  ✓ Noisy SNN accuracy={noisy_acc:.1f}% — in the sweet spot (85-94%).")

    noise_helps = noisy_ens['mean_error_correlation'] < control_ens['mean_error_correlation']
    print(f"\n  VERDICT: Noise {'INCREASES' if noise_helps else 'DOES NOT INCREASE'} diversity "
          f"beyond random initialisation alone")
    if noise_helps:
        improvement = control_ens['mean_error_correlation'] - noisy_ens['mean_error_correlation']
        print(f"  Error correlation reduced by {improvement:.4f} "
              f"({improvement/control_ens['mean_error_correlation']*100:.1f}% relative)")

    # ============================================================
    # FULL ENSEMBLE ANALYSIS (noisy SNNs)
    # ============================================================
    print(f"\n[7/7] Full ensemble analysis (noisy SNNs)...")

    ensemble_results = {}
    ood_detection_results = {}

    print(f"\n{'='*70}")
    print(f"{'N':>3} | {'Soft Acc':>8} | {'Hard Acc':>8} | {'Best Ind':>8} | "
          f"{'Emerge':>7} | {'Err Corr':>8} | {'Split':>7}")
    print(f"{'-'*70}")

    for n in config['ensemble_sizes']:
        if n > len(snn_results):
            continue

        ens = analyse_ensemble(snn_results, targets, ensemble_size=n)
        ensemble_results[n] = ens

        ood_det = analyse_ood_detection(snn_results, ood_results, ensemble_size=n)
        ood_detection_results[n] = ood_det

        print(f"{n:>3} | {ens['soft_accuracy']*100:>7.1f}% | "
              f"{ens['hard_accuracy']*100:>7.1f}% | "
              f"{ens['best_individual_accuracy']*100:>7.1f}% | "
              f"{ens['emergence_count']:>7d} | "
              f"{ens['mean_error_correlation']:>8.3f} | "
              f"{ens['split_vote']*100:>6.1f}%")

    # Cost analysis
    print(f"\n{'='*60}")
    print("COST ANALYSIS (relative to single ANN = 1.0)")
    print(f"{'='*60}")
    costs = cost_analysis(snn_results, ann_result, ensemble_results, config)
    for n, c in costs.items():
        print(f"  N={n:>2}: Cost={c['cost_ratio']:.2f}x | "
              f"Ens Acc={c['ensemble_accuracy']*100:.1f}% vs ANN={c['ann_accuracy']*100:.1f}%")

    # OOD detection results
    print(f"\n{'='*60}")
    print("OOD DETECTION (Fashion-MNIST vs MNIST digits)")
    print(f"{'='*60}")
    for n, ood in ood_detection_results.items():
        print(f"  N={n:>2}: In-dist disagreement={ood['in_dist_mean_disagreement']:.3f}, "
              f"OOD disagreement={ood['ood_mean_disagreement']:.3f}, "
              f"Detection={ood['ood_detection_rate']*100:.1f}%, "
              f"False alarm={ood['in_dist_false_alarm_rate']*100:.1f}%")

    # Emergence details
    print(f"\n{'='*60}")
    print("EMERGENCE ANALYSIS — SOFT VOTE")
    print("(ensemble right via averaged probabilities, ALL individuals wrong)")
    print(f"{'='*60}")
    for n in config['ensemble_sizes']:
        if n not in ensemble_results:
            continue
        ens = ensemble_results[n]
        print(f"\n  N={n}: {ens['emergence_count']} soft emergence "
              f"({ens['emergence_rate']*100:.2f}% of test set) | "
              f"{ens['hard_emergence_count']} hard emergence")
        if ens['emergence_count'] > 0:
            print(f"    Per-class: {ens['per_class_emergence']}")

    # Show emergence examples for best N
    best_n = max(ensemble_results.keys(),
                 key=lambda n: (ensemble_results[n]['emergence_count'],
                                ensemble_results[n]['ensemble_accuracy']))
    best_ens = ensemble_results[best_n]

    if best_ens['emergence_count'] > 0 and best_ens['emergence_details']:
        print(f"\n  EMERGENCE EXAMPLES (N={best_n}, first 10):")
        print(f"  {'Idx':>5} | {'True':>4} | {'Soft':>4} | {'Avg P(true)':>10} | "
              f"{'Ranks':>30} | {'Individual preds'}")
        print(f"  {'-'*90}")
        for d in best_ens['emergence_details'][:10]:
            ranks_str = str(d['individual_ranks'][:best_n])
            preds_str = str(d['individual_preds'][:best_n])
            print(f"  {d['idx']:>5} | {d['true_label']:>4} | {d['soft_pred']:>4} | "
                  f"{d['mean_prob_correct']:>10.4f} | "
                  f"{ranks_str:>30} | {preds_str}")

        # Summary stats on emergence cases
        all_ranks = [r for d in best_ens['emergence_details']
                     for r in d['individual_ranks'][:best_n]]
        all_probs = [p for d in best_ens['emergence_details']
                     for p in d['individual_probs'][:best_n]]
        print(f"\n  Emergence pattern summary:")
        print(f"    Mean rank of true class across individuals: {np.mean(all_ranks):.1f}")
        print(f"    Mean P(true class) across individuals: {np.mean(all_probs):.4f}")
        print(f"    → True class is typically the {int(np.mean(all_ranks))}th choice "
              f"for individual networks")
        print(f"    → But averaging {best_n} networks' ~{np.mean(all_probs):.1%} "
              f"probability is enough to win")

    # Error decorrelation analysis
    print(f"\n{'='*60}")
    print("ERROR DECORRELATION vs N")
    print(f"{'='*60}")
    for n in config['ensemble_sizes']:
        if n not in ensemble_results:
            continue
        ens = ensemble_results[n]
        print(f"  N={n:>2}: Mean error correlation = {ens['mean_error_correlation']:.4f}")

    # Summary
    print(f"\n{'='*60}")
    print("SUMMARY")
    print(f"{'='*60}")

    any_emergence = any(ensemble_results[n]['emergence_count'] > 0
                        for n in ensemble_results)

    # Check if error correlation trends down with N
    corr_values = [(n, ensemble_results[n]['mean_error_correlation'])
                   for n in sorted(ensemble_results.keys())]
    corr_trend = "decreases" if corr_values[-1][1] < corr_values[0][1] else "flat/increases"

    # Best soft accuracy
    best_soft_n = max(ensemble_results.keys(),
                      key=lambda n: ensemble_results[n]['soft_accuracy'])
    # Best emergence
    best_emrg_n = max(ensemble_results.keys(),
                      key=lambda n: (ensemble_results[n]['emergence_count'],
                                     ensemble_results[n]['soft_accuracy']))
    best_ens = ensemble_results[best_emrg_n]

    print(f"""
  ANN baseline accuracy:           {ann_result['accuracy']*100:.1f}%
  Best individual SNN accuracy:    {max(r['accuracy'] for r in snn_results)*100:.1f}%
  Best SOFT ensemble acc (N={best_soft_n}):  {ensemble_results[best_soft_n]['soft_accuracy']*100:.1f}%
  Best HARD ensemble acc (N={best_soft_n}):  {ensemble_results[best_soft_n]['hard_accuracy']*100:.1f}%
  Soft vs Hard accuracy gain:      {(ensemble_results[best_soft_n]['soft_accuracy']-ensemble_results[best_soft_n]['hard_accuracy'])*100:+.2f}%

  Total emergence cases (N={best_emrg_n}):   {best_ens['emergence_count']} (soft) vs {best_ens['hard_emergence_count']} (hard)
  Error correlation {corr_trend} with N ({corr_values[0][1]:.4f} at N={corr_values[0][0]} → {corr_values[-1][1]:.4f} at N={corr_values[-1][0]})

  {'EMERGENCE DETECTED' if any_emergence else 'NO EMERGENCE DETECTED'} via soft voting
  {'→ Second-choice agreement produces collective knowledge!' if any_emergence else '→ Second-choice agreement insufficient at this diversity level'}

  Cost crossover: ensemble exceeds ANN cost at N ≈ {1.0 / np.mean([r.get('activation_rate', 0.28) for r in snn_results]):.1f}
  (On neuromorphic hardware at ~1000x efficiency, crossover moves to N ≈ {1000.0 / np.mean([r.get('activation_rate', 0.28) for r in snn_results]):.0f})
    """)

    return {
        'config': {k: v for k, v in config.items() if k != 'device'},
        'snn_results': [{
            'accuracy': r['accuracy'],
            'activation_rate': r.get('activation_rate', 0)
        } for r in snn_results],
        'ann_accuracy': ann_result['accuracy'],
        'ensemble_results': {
            n: {k: v for k, v in ens.items()
                if k not in ('ensemble_preds', 'ensemble_correct')}
            for n, ens in ensemble_results.items()
        },
        'ood_detection': ood_detection_results,
        'costs': costs,
    }


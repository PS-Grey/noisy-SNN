def load_data(config):
    """Load full Fashion-MNIST train/test and MNIST as OOD."""
    transform = transforms.Compose([
        transforms.ToTensor(),
        transforms.Normalize((0.2860,), (0.3530,))  # Fashion-MNIST stats
    ])

    # PRIMARY TASK: Fashion-MNIST (harder — ~85-88% SNN accuracy expected)
    train_data = datasets.FashionMNIST('./data', train=True, download=True, transform=transform)
    test_data = datasets.FashionMNIST('./data', train=False, download=True, transform=transform)

    train_loader = DataLoader(train_data, batch_size=config['batch_size'],
                              shuffle=True, num_workers=2, pin_memory=True)
    test_loader = DataLoader(test_data, batch_size=config['batch_size'],
                             shuffle=False, num_workers=2, pin_memory=True)

    # OOD: MNIST digits (same dimensions, different distribution)
    ood_data = datasets.MNIST('./data', train=False, download=True, transform=transform)
    ood_loader = DataLoader(ood_data, batch_size=config['batch_size'],
                            shuffle=False, num_workers=2, pin_memory=True)

    return train_loader, test_loader, ood_loader

# ============================================================
# TRAINING
# ============================================================

def train_snn(model, train_loader, config, snn_id=0):
    """Train a single SNN."""
    optimizer = torch.optim.Adam(model.parameters(), lr=config['lr'])
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, config['epochs'])
    criterion = nn.CrossEntropyLoss()
    device = config['device']
    model = model.to(device)

    print(f"\n  SNN-{snn_id}: Training...")
    for epoch in range(config['epochs']):
        model.train()
        total_loss = 0
        correct = 0
        total = 0

        for data, target in train_loader:
            data, target = data.to(device), target.to(device)
            optimizer.zero_grad()

            output, _, _ = model(data)
            loss = criterion(output, target)
            loss.backward()

            # Gradient clipping for SNN stability
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()

            total_loss += loss.item()
            _, predicted = output.max(1)
            correct += predicted.eq(target).sum().item()
            total += target.size(0)

        scheduler.step()
        acc = 100. * correct / total

        if (epoch + 1) % 5 == 0 or epoch == 0:
            print(f"    Epoch {epoch+1}/{config['epochs']}: "
                  f"Loss={total_loss/len(train_loader):.4f}, Acc={acc:.1f}%")

    return model


def train_ann(model, train_loader, config):
    """Train the ANN baseline."""
    optimizer = torch.optim.Adam(model.parameters(), lr=config['lr'])
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, config['epochs'])
    criterion = nn.CrossEntropyLoss()
    device = config['device']
    model = model.to(device)

    print("\n  ANN: Training...")
    for epoch in range(config['epochs']):
        model.train()
        correct = 0
        total = 0

        for data, target in train_loader:
            data, target = data.to(device), target.to(device)
            optimizer.zero_grad()
            output = model(data)
            loss = criterion(output, target)
            loss.backward()
            optimizer.step()

            _, predicted = output.max(1)
            correct += predicted.eq(target).sum().item()
            total += target.size(0)

        scheduler.step()

        if (epoch + 1) % 5 == 0 or epoch == 0:
            acc = 100. * correct / total
            print(f"    Epoch {epoch+1}/{config['epochs']}: Acc={acc:.1f}%")

    return model

# ============================================================
# EVALUATION
# ============================================================

def evaluate_single(model, test_loader, config, is_snn=True):
    """Evaluate a single model. Returns predictions, confidences, full probs, correctness."""
    device = config['device']
    model.eval()
    model = model.to(device)

    all_preds = []
    all_confs = []
    all_probs = []
    all_targets = []
    all_correct = []
    total_activation = 0
    n_batches = 0

    with torch.no_grad():
        for data, target in test_loader:
            data, target = data.to(device), target.to(device)

            if is_snn:
                output, _, act_rate = model(data)
                total_activation += act_rate
                n_batches += 1
            else:
                output = model(data)

            probs = F.softmax(output, dim=1)
            conf, pred = probs.max(dim=1)

            all_preds.append(pred.cpu())
            all_confs.append(conf.cpu())
            all_probs.append(probs.cpu())
            all_targets.append(target.cpu())
            all_correct.append(pred.eq(target).cpu())

    results = {
        'preds': torch.cat(all_preds),
        'confs': torch.cat(all_confs),
        'probs': torch.cat(all_probs),       # [n_samples, n_classes]
        'targets': torch.cat(all_targets),
        'correct': torch.cat(all_correct),
        'accuracy': torch.cat(all_correct).float().mean().item(),
    }

    if is_snn:
        results['activation_rate'] = total_activation / n_batches

    return results

# ============================================================
# ENSEMBLE ANALYSIS
# ============================================================

def analyse_ensemble(snn_results_list, targets, ensemble_size=None):
    """
    Analyse ensemble of diverse SNNs using both hard and soft voting.

    Hard vote: confidence-weighted plurality (each network's top-1 prediction).
    Soft vote: average full probability distributions, then argmax.

    Emergence is measured on SOFT vote — the mechanism by which second-choice
    agreement across networks can produce correct answers that no individual gives.
    """
    if ensemble_size is None:
        ensemble_size = len(snn_results_list)

    results = snn_results_list[:ensemble_size]
    n_samples = len(targets)
    n_models = len(results)

    # Stack all predictions: shape [n_models, n_samples]
    all_preds = torch.stack([r['preds'] for r in results])
    all_confs = torch.stack([r['confs'] for r in results])
    all_correct = torch.stack([r['correct'] for r in results])

    # Stack full probability distributions: shape [n_models, n_samples, n_classes]
    all_probs = torch.stack([r['probs'] for r in results])

    # ===========================================
    # HARD VOTE (confidence-weighted plurality)
    # ===========================================
    hard_preds = []
    for i in range(n_samples):
        vote_weights = {}
        for m in range(n_models):
            pred = int(all_preds[m, i])
            conf = float(all_confs[m, i])
            vote_weights[pred] = vote_weights.get(pred, 0) + conf
        hard_preds.append(max(vote_weights, key=vote_weights.get))

    hard_preds = torch.tensor(hard_preds)
    hard_correct = hard_preds.eq(targets)
    hard_accuracy = hard_correct.float().mean().item()

    # ===========================================
    # SOFT VOTE (average probability distributions)
    # ===========================================
    # Average across models: [n_samples, n_classes]
    mean_probs = all_probs.mean(dim=0)
    soft_preds = mean_probs.argmax(dim=1)
    soft_correct = soft_preds.eq(targets)
    soft_accuracy = soft_correct.float().mean().item()

    # ===========================================
    # EMERGENCE (on soft vote — where it can actually occur)
    # ===========================================
    # All individuals wrong, but soft ensemble right
    all_individual_wrong = (all_correct.sum(dim=0) == 0)
    soft_emergence_mask = all_individual_wrong & soft_correct
    soft_emergence_count = soft_emergence_mask.sum().item()
    soft_emergence_rate = soft_emergence_count / n_samples

    # Also track hard emergence for comparison (should still be ~0)
    hard_emergence_mask = all_individual_wrong & hard_correct
    hard_emergence_count = hard_emergence_mask.sum().item()

    # ===========================================
    # SOFT VOTE MECHANICS — why did emergence happen?
    # ===========================================
    # For emergence cases, analyse the probability distributions
    emergence_details = []
    if soft_emergence_count > 0:
        emergence_indices = torch.where(soft_emergence_mask)[0][:20]  # first 20
        for idx in emergence_indices:
            idx_val = idx.item()
            true_label = targets[idx_val].item()
            soft_pred = soft_preds[idx_val].item()
            mean_prob_correct = float(mean_probs[idx_val, true_label])

            # What rank was the true class for each individual?
            ranks = []
            individual_probs_for_true = []
            for m in range(n_models):
                prob_vec = all_probs[m, idx_val]
                rank = (prob_vec > prob_vec[true_label]).sum().item() + 1
                ranks.append(rank)
                individual_probs_for_true.append(float(prob_vec[true_label]))

            emergence_details.append({
                'idx': idx_val,
                'true_label': true_label,
                'soft_pred': soft_pred,
                'mean_prob_correct': mean_prob_correct,
                'individual_ranks': ranks,
                'individual_probs': individual_probs_for_true,
                'individual_preds': [int(all_preds[m, idx_val]) for m in range(n_models)],
            })

    # ===========================================
    # ERROR DECORRELATION
    # ===========================================
    error_correlations = []
    for i in range(n_models):
        for j in range(i + 1, n_models):
            errors_i = (~all_correct[i]).float()
            errors_j = (~all_correct[j]).float()
            if errors_i.std() > 0 and errors_j.std() > 0:
                corr = torch.corrcoef(torch.stack([errors_i, errors_j]))[0, 1].item()
                error_correlations.append(corr)

    mean_error_corr = np.mean(error_correlations) if error_correlations else 0

    # ===========================================
    # DISAGREEMENT PATTERNS
    # ===========================================
    agreement_patterns = []
    unanimous_correct = 0
    unanimous_wrong = 0
    split_vote = 0

    for i in range(n_samples):
        preds_i = all_preds[:, i].tolist()
        unique_preds = len(set(preds_i))

        if unique_preds == 1:
            if all_correct[0, i]:
                unanimous_correct += 1
            else:
                unanimous_wrong += 1
        else:
            split_vote += 1

        agreement_patterns.append(unique_preds)

    # ===========================================
    # PER-CLASS EMERGENCE
    # ===========================================
    per_class_emergence = {}
    for c in range(10):
        class_mask = (targets == c)
        if class_mask.sum() > 0:
            class_emergence = (soft_emergence_mask & class_mask).sum().item()
            per_class_emergence[c] = class_emergence

    return {
        # Soft vote (primary)
        'ensemble_accuracy': soft_accuracy,
        'soft_accuracy': soft_accuracy,
        'soft_preds': soft_preds,
        'soft_correct': soft_correct,
        'emergence_count': soft_emergence_count,
        'emergence_rate': soft_emergence_rate,
        'emergence_details': emergence_details,
        # Hard vote (comparison)
        'hard_accuracy': hard_accuracy,
        'hard_emergence_count': hard_emergence_count,
        # Individual
        'individual_accuracies': [r['accuracy'] for r in results],
        'mean_individual_accuracy': np.mean([r['accuracy'] for r in results]),
        'best_individual_accuracy': max([r['accuracy'] for r in results]),
        # Diversity metrics
        'mean_error_correlation': mean_error_corr,
        'unanimous_correct': unanimous_correct / n_samples,
        'unanimous_wrong': unanimous_wrong / n_samples,
        'split_vote': split_vote / n_samples,
        'per_class_emergence': per_class_emergence,
        'n_models': n_models,
        'ensemble_preds': soft_preds,
        'ensemble_correct': soft_correct,
        'agreement_diversity': np.mean(agreement_patterns),
    }


def analyse_ood_detection(snn_results_list, ood_results_list, ensemble_size=None):
    """
    Test whether disagreement among diverse SNNs detects
    out-of-distribution inputs (Fashion-MNIST vs MNIST).
    """
    if ensemble_size is None:
        ensemble_size = len(snn_results_list)

    in_dist = snn_results_list[:ensemble_size]
    ood = ood_results_list[:ensemble_size]

    def disagreement_score(results_list):
        """Fraction of models that disagree with majority for each input."""
        n_samples = len(results_list[0]['preds'])
        scores = []
        for i in range(n_samples):
            preds = [int(r['preds'][i]) for r in results_list]
            majority = Counter(preds).most_common(1)[0][1]
            disagreement = 1.0 - (majority / len(preds))
            scores.append(disagreement)
        return torch.tensor(scores)

    def confidence_score(results_list):
        """Mean confidence across ensemble for each input."""
        confs = torch.stack([r['confs'] for r in results_list])
        return confs.mean(dim=0)

    in_disagreement = disagreement_score(in_dist)
    ood_disagreement = disagreement_score(ood)

    in_confidence = confidence_score(in_dist)
    ood_confidence = confidence_score(ood)

    # Can we separate in-distribution from OOD using disagreement?
    # Simple threshold: what fraction of OOD has higher disagreement than median in-dist?
    threshold = in_disagreement.median().item()
    ood_detected = (ood_disagreement > threshold).float().mean().item()
    in_false_alarm = (in_disagreement > threshold).float().mean().item()

    return {
        'in_dist_mean_disagreement': in_disagreement.mean().item(),
        'ood_mean_disagreement': ood_disagreement.mean().item(),
        'in_dist_mean_confidence': in_confidence.mean().item(),
        'ood_mean_confidence': ood_confidence.mean().item(),
        'ood_detection_rate': ood_detected,
        'in_dist_false_alarm_rate': in_false_alarm,
        'separation': ood_disagreement.mean().item() - in_disagreement.mean().item(),
    }

# ============================================================
# COST ANALYSIS
# ============================================================

def cost_analysis(snn_results_list, ann_result, ensemble_analysis_results, config):
    """
    Compare cost of ensemble + ANN escalation vs ANN alone.
    SNN cost = activation_rate (fraction of neurons active).
    ANN cost = 1.0 (all neurons active).
    """
    results = {}
    snn_cost_per_unit = np.mean([r.get('activation_rate', 0.28) for r in snn_results_list])

    for n in config['ensemble_sizes']:
        if n > len(snn_results_list):
            continue

        ens = ensemble_analysis_results.get(n, {})
        split_rate = ens.get('split_vote', 0.5)

        # Cost: N SNNs (parallel) + ANN on splits
        ensemble_cost = n * snn_cost_per_unit + split_rate * 1.0
        ann_only_cost = 1.0

        results[n] = {
            'ensemble_cost': ensemble_cost,
            'ann_only_cost': ann_only_cost,
            'cost_ratio': ensemble_cost / ann_only_cost,
            'ensemble_accuracy': ens.get('ensemble_accuracy', 0),
            'ann_accuracy': ann_result['accuracy'],
            'snn_cost_per_unit': snn_cost_per_unit,
            'split_rate': split_rate,
        }

    return results


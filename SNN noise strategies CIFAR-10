def run_experiment():
    config = CONFIG
    print("=" * 65)
    print("NOISE SCALING STRATEGIES — CIFAR-10")
    print("=" * 65)

    print("\n[1] Loading CIFAR-10...")
    train_loader, test_loader = load_data(config)
    print("  50K train (augmented), 10K test")

    all_results = {}

    # ============================================================
    # [2] CONTROL — no noise
    # ============================================================
    print("\n[2] Control (no noise)...")
    torch.manual_seed(42)
    model = ConvSNN(config, noise_strategy=NoNoise())
    result = train_and_eval(model, train_loader, test_loader, config,
                            name="Control", is_snn=True)
    all_results['Control'] = result
    print(f"    → Final: {result['accuracy']*100:.1f}% (best: {result['best_accuracy']*100:.1f}%)")

    # ============================================================
    # [3] STRATEGY A — Fixed noise
    # ============================================================
    print("\n[3] Strategy A: Fixed noise...")
    for std in config['fixed_values']:
        key = f"Fixed({std})"
        torch.manual_seed(42)
        model = ConvSNN(config, noise_strategy=FixedNoise(std))
        result = train_and_eval(model, train_loader, test_loader, config,
                                name=key, is_snn=True)
        all_results[key] = result
        print(f"    → Final: {result['accuracy']*100:.1f}% "
              f"(best: {result['best_accuracy']*100:.1f}%), Act: {result['activation_rate']:.3f}")

    # ============================================================
    # [4] STRATEGY B — Threshold-relative noise
    # ============================================================
    print("\n[4] Strategy B: Threshold-relative noise...")
    for alpha in config['threshold_alphas']:
        key = f"Threshold(α={alpha})"
        torch.manual_seed(42)
        model = ConvSNN(config, noise_strategy=ThresholdNoise(alpha))
        result = train_and_eval(model, train_loader, test_loader, config,
                                name=key, is_snn=True)
        all_results[key] = result
        print(f"    → Final: {result['accuracy']*100:.1f}% "
              f"(best: {result['best_accuracy']*100:.1f}%), Act: {result['activation_rate']:.3f}")

    # ============================================================
    # [5] STRATEGY C — Signal-relative noise
    # ============================================================
    print("\n[5] Strategy C: Signal-relative noise...")
    for alpha in config['signal_alphas']:
        key = f"Signal(α={alpha})"
        torch.manual_seed(42)
        model = ConvSNN(config, noise_strategy=SignalNoise(alpha))
        result = train_and_eval(model, train_loader, test_loader, config,
                                name=key, is_snn=True)
        all_results[key] = result
        print(f"    → Final: {result['accuracy']*100:.1f}% "
              f"(best: {result['best_accuracy']*100:.1f}%), Act: {result['activation_rate']:.3f}")

    # ============================================================
    # [6] STRATEGY D — Learned noise
    # ============================================================
    print("\n[6] Strategy D: Learned noise...")
    for init in config['learned_inits']:
        key = f"Learned(init={init})"
        torch.manual_seed(42)
        model = ConvSNN(config, noise_strategy=LearnedNoise(init))
        result = train_and_eval(model, train_loader, test_loader, config,
                                name=key, is_snn=True)
        all_results[key] = result
        learned = result.get('learned_noise')
        learned_str = ""
        if learned:
            learned_str = (f" | Final noise: c1={learned['conv1']:.3f}, "
                          f"c2={learned['conv2']:.3f}, c3={learned['conv3']:.3f}, "
                          f"fc={learned['fc']:.3f}")
        print(f"    → Final: {result['accuracy']*100:.1f}% "
              f"(best: {result['best_accuracy']*100:.1f}%), "
              f"Act: {result['activation_rate']:.3f}{learned_str}")

    # ============================================================
    # [7] CNN-ANN BASELINE
    # ============================================================
    print("\n[7] CNN-ANN baseline...")
    torch.manual_seed(42)
    ann = BaselineCNN(config)
    ann_result = train_and_eval(ann, train_loader, test_loader, config,
                                name="CNN-ANN", is_snn=False)
    all_results['CNN-ANN'] = ann_result
    print(f"    → Final: {ann_result['accuracy']*100:.1f}% "
          f"(best: {ann_result['best_accuracy']*100:.1f}%)")

    # ============================================================
    # [8] RESULTS SUMMARY
    # ============================================================
    print(f"\n{'='*65}")
    print("RESULTS SUMMARY — CIFAR-10")
    print(f"{'='*65}")

    print(f"\n  {'Strategy':<25} {'Test Acc':>8} {'Best Acc':>8} {'Act Rate':>8}")
    print(f"  {'-'*55}")

    # Sort by accuracy
    sorted_results = sorted(all_results.items(),
                            key=lambda x: x[1]['accuracy'], reverse=True)
    for key, r in sorted_results:
        act = f"{r['activation_rate']:.3f}" if r['activation_rate'] > 0 else "  N/A"
        print(f"  {key:<25} {r['accuracy']*100:>7.1f}% {r['best_accuracy']*100:>7.1f}% {act:>8}")

    # ============================================================
    # [9] ANALYSIS BY STRATEGY TYPE
    # ============================================================
    print(f"\n{'='*65}")
    print("BEST α PER STRATEGY")
    print(f"{'='*65}")

    strategies = {
        'Fixed': [(k, v) for k, v in all_results.items() if k.startswith('Fixed')],
        'Threshold': [(k, v) for k, v in all_results.items() if k.startswith('Threshold')],
        'Signal': [(k, v) for k, v in all_results.items() if k.startswith('Signal')],
        'Learned': [(k, v) for k, v in all_results.items() if k.startswith('Learned')],
    }

    best_per_strategy = {}
    for strat_name, entries in strategies.items():
        if entries:
            best = max(entries, key=lambda x: x[1]['accuracy'])
            best_per_strategy[strat_name] = best
            print(f"\n  {strat_name}: best = {best[0]}")
            print(f"    Accuracy: {best[1]['accuracy']*100:.1f}% | "
                  f"Activation: {best[1]['activation_rate']:.3f}")

    control_acc = all_results['Control']['accuracy']
    ann_acc = all_results['CNN-ANN']['accuracy']

    print(f"\n  Control (no noise): {control_acc*100:.1f}%")
    print(f"  CNN-ANN baseline:   {ann_acc*100:.1f}%")

    # Winner
    print(f"\n{'='*65}")
    print("VERDICT")
    print(f"{'='*65}")

    winner_key, winner_result = sorted_results[0]
    if winner_key == 'CNN-ANN':
        winner_key, winner_result = sorted_results[1]  # best SNN
        print(f"\n  Best SNN strategy: {winner_key}")
        print(f"    {winner_result['accuracy']*100:.1f}% vs CNN-ANN {ann_acc*100:.1f}% "
              f"(gap: {(ann_acc - winner_result['accuracy'])*100:.1f}%)")
    else:
        print(f"\n  Best overall: {winner_key}")
        print(f"    SNN beats CNN-ANN! {winner_result['accuracy']*100:.1f}% vs {ann_acc*100:.1f}%")

    noise_gain = winner_result['accuracy'] - control_acc
    print(f"  Noise gain over control: {noise_gain*100:+.1f}%")

    # Learned noise analysis
    for key, r in all_results.items():
        if r.get('learned_noise'):
            print(f"\n  {key} — learned noise levels:")
            for layer, val in r['learned_noise'].items():
                print(f"    {layer}: {val:.4f}")

    # Error correlation between best of each strategy
    print(f"\n{'='*65}")
    print("CROSS-STRATEGY ERROR CORRELATION")
    print(f"{'='*65}")

    corr_keys = ['Control']
    for strat_name, (key, _) in best_per_strategy.items():
        corr_keys.append(key)

    print(f"\n  {'':>25}", end="")
    for k in corr_keys:
        short = k[:12]
        print(f" {short:>12}", end="")
    print()

    for ki in corr_keys:
        print(f"  {ki:<25}", end="")
        for kj in corr_keys:
            if ki == kj:
                print(f" {'—':>12}", end="")
            else:
                ei = (~all_results[ki]['correct']).float()
                ej = (~all_results[kj]['correct']).float()
                if ei.std() > 0 and ej.std() > 0:
                    c = torch.corrcoef(torch.stack([ei, ej]))[0, 1].item()
                    print(f" {c:>12.3f}", end="")
                else:
                    print(f" {'N/A':>12}", end="")
        print()

    return all_results



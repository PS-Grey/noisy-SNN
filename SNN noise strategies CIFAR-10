# BASELINE CNN-ANN
# ============================================================

class BaselineCNN(nn.Module):
    def __init__(self, config):
        super().__init__()
        c1, c2, c3 = config['conv1_filters'], config['conv2_filters'], config['conv3_filters']
        ks, pad = config['kernel_size'], config['kernel_size'] // 2
        self.features = nn.Sequential(
            nn.Conv2d(config['input_channels'], c1, ks, padding=pad),
            nn.BatchNorm2d(c1), nn.ReLU(), nn.MaxPool2d(2),
            nn.Conv2d(c1, c2, ks, padding=pad),
            nn.BatchNorm2d(c2), nn.ReLU(), nn.MaxPool2d(2),
            nn.Conv2d(c2, c3, ks, padding=pad),
            nn.BatchNorm2d(c3), nn.ReLU(), nn.MaxPool2d(2),
        )
        flat_size = c3 * 4 * 4
        self.classifier = nn.Sequential(
            nn.Linear(flat_size, config['hidden_size']),
            nn.BatchNorm1d(config['hidden_size']),
            nn.ReLU(), nn.Dropout(0.3),
            nn.Linear(config['hidden_size'], config['output_size']),
        )

    def forward(self, x):
        x = self.features(x)
        x = x.view(x.size(0), -1)
        return self.classifier(x)

# ============================================================
# DATA
# ============================================================

def load_data(config):
    train_transform = transforms.Compose([
        transforms.RandomCrop(32, padding=4),
        transforms.RandomHorizontalFlip(),
        transforms.ToTensor(),
        transforms.Normalize((0.4914, 0.4822, 0.4465), (0.2470, 0.2435, 0.2616))
    ])
    test_transform = transforms.Compose([
        transforms.ToTensor(),
        transforms.Normalize((0.4914, 0.4822, 0.4465), (0.2470, 0.2435, 0.2616))
    ])
    train_data = datasets.CIFAR10('./data', train=True, download=True,
                                   transform=train_transform)
    test_data = datasets.CIFAR10('./data', train=False, download=True,
                                  transform=test_transform)
    train_loader = DataLoader(train_data, batch_size=config['batch_size'],
                              shuffle=True, num_workers=2, pin_memory=True)
    test_loader = DataLoader(test_data, batch_size=config['batch_size'],
                             shuffle=False, num_workers=2, pin_memory=True)
    return train_loader, test_loader

# ============================================================
# TRAINING & EVALUATION
# ============================================================

def train_and_eval(model, train_loader, test_loader, config, name, is_snn=True):
    optimizer = torch.optim.Adam(model.parameters(), lr=config['lr'])
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, config['epochs'])
    criterion = nn.CrossEntropyLoss()
    device = config['device']
    model = model.to(device)

    best_acc = 0
    print(f"\n  {name}:")

    for epoch in range(config['epochs']):
        model.train()
        correct = 0
        total = 0
        total_loss = 0

        for data, target in train_loader:
            data, target = data.to(device), target.to(device)
            optimizer.zero_grad()
            if is_snn:
                output, _ = model(data)
            else:
                output = model(data)
            loss = criterion(output, target)
            loss.backward()
            if is_snn:
                torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()
            total_loss += loss.item()
            _, predicted = output.max(1)
            correct += predicted.eq(target).sum().item()
            total += target.size(0)

        scheduler.step()
        train_acc = 100. * correct / total

        # Eval
        model.eval()
        test_correct = 0
        test_total = 0
        total_act = 0
        n_batches = 0

        with torch.no_grad():
            for data, target in test_loader:
                data, target = data.to(device), target.to(device)
                if is_snn:
                    output, act = model(data)
                    total_act += act
                    n_batches += 1
                else:
                    output = model(data)
                _, predicted = output.max(1)
                test_correct += predicted.eq(target).sum().item()
                test_total += target.size(0)

        test_acc = 100. * test_correct / test_total
        if test_acc > best_acc:
            best_acc = test_acc

        if (epoch + 1) % 10 == 0 or epoch == 0:
            act_str = f", Act: {total_act/n_batches:.3f}" if is_snn and n_batches > 0 else ""
            learned_str = ""
            if is_snn and isinstance(model.noise_strategy, LearnedNoise):
                stds = model.get_learned_noise_stds()
                if stds:
                    learned_str = (f"\n      Learned noise: "
                                   f"c1={stds['conv1']:.3f}, c2={stds['conv2']:.3f}, "
                                   f"c3={stds['conv3']:.3f}, fc={stds['fc']:.3f}")
            print(f"    Epoch {epoch+1}/{config['epochs']}: "
                  f"Train={train_acc:.1f}%, Test={test_acc:.1f}%{act_str}{learned_str}")

    # Final evaluation with full details
    model.eval()
    all_logits = []
    all_preds = []
    all_targets = []
    all_correct = []
    total_act = 0
    n_batches = 0

    with torch.no_grad():
        for data, target in test_loader:
            data, target = data.to(device), target.to(device)
            if is_snn:
                output, act = model(data)
                total_act += act
                n_batches += 1
            else:
                output = model(data)
            all_logits.append(output.cpu())
            pred = output.argmax(dim=1)
            all_preds.append(pred.cpu())
            all_targets.append(target.cpu())
            all_correct.append(pred.eq(target).cpu())

    return {
        'logits': torch.cat(all_logits),
        'preds': torch.cat(all_preds),
        'targets': torch.cat(all_targets),
        'correct': torch.cat(all_correct),
        'accuracy': torch.cat(all_correct).float().mean().item(),
        'best_accuracy': best_acc / 100,
        'activation_rate': total_act / n_batches if n_batches > 0 else 0,
        'learned_noise': model.get_learned_noise_stds() if is_snn and hasattr(model, 'get_learned_noise_stds') else None,
    }


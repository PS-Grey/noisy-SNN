# ============================================================
# SURROGATE GRADIENT
# ============================================================

class SurrogateSpike(torch.autograd.Function):
    scale = 25.0
    @staticmethod
    def forward(ctx, membrane):
        spikes = (membrane > 0).float()
        ctx.save_for_backward(membrane)
        return spikes
    @staticmethod
    def backward(ctx, grad_output):
        membrane, = ctx.saved_tensors
        sigmoid = torch.sigmoid(SurrogateSpike.scale * membrane)
        return grad_output * sigmoid * (1 - sigmoid) * SurrogateSpike.scale

spike_fn = SurrogateSpike.apply

# ============================================================
# NOISE STRATEGIES
# ============================================================

class NoiseStrategy:
    """Base class for noise injection strategies."""
    def get_noise(self, membrane, bn_layer=None, threshold=1.0, training=True):
        """Return noise tensor to add to membrane potential."""
        raise NotImplementedError

    def describe(self):
        raise NotImplementedError

    def get_effective_std(self):
        """Return current effective noise std for reporting."""
        return 0.0


class FixedNoise(NoiseStrategy):
    def __init__(self, noise_std):
        self.noise_std = noise_std

    def get_noise(self, membrane, bn_layer=None, threshold=1.0, training=True):
        if not training or self.noise_std == 0:
            return 0
        return torch.randn_like(membrane) * self.noise_std

    def describe(self):
        return f"Fixed(std={self.noise_std})"

    def get_effective_std(self):
        return self.noise_std


class ThresholdNoise(NoiseStrategy):
    def __init__(self, alpha):
        self.alpha = alpha

    def get_noise(self, membrane, bn_layer=None, threshold=1.0, training=True):
        if not training:
            return 0
        noise_std = self.alpha * threshold
        return torch.randn_like(membrane) * noise_std

    def describe(self):
        return f"Threshold(α={self.alpha})"

    def get_effective_std(self):
        return self.alpha  # relative to threshold


class SignalNoise(NoiseStrategy):
    def __init__(self, alpha):
        self.alpha = alpha

    def get_noise(self, membrane, bn_layer=None, threshold=1.0, training=True):
        if not training or bn_layer is None:
            return 0
        # Scale noise by signal statistics from batch norm
        signal_std = torch.sqrt(bn_layer.running_var + 1e-5)
        # Reshape to [1, C, 1, 1] for conv or [1, C] for FC
        shape = [1] * membrane.dim()
        shape[1] = -1  # channel dimension is always dim 1
        signal_std = signal_std.view(*shape)
        noise_std = self.alpha * signal_std
        return torch.randn_like(membrane) * noise_std

    def describe(self):
        return f"Signal(α={self.alpha})"

    def get_effective_std(self):
        return self.alpha  # relative to signal std


class LearnedNoise(NoiseStrategy):
    """Wrapper — actual parameters live in the model."""
    def __init__(self, init_std):
        self.init_std = init_std

    def describe(self):
        return f"Learned(init={self.init_std})"

    def get_effective_std(self):
        return self.init_std


class NoNoise(NoiseStrategy):
    def get_noise(self, membrane, bn_layer=None, threshold=1.0, training=True):
        return 0

    def describe(self):
        return "None(control)"

    def get_effective_std(self):
        return 0.0

# ============================================================
# CONV-SNN MODEL
# ============================================================

class ConvSNN(nn.Module):
    """
    3-layer spiking CNN for CIFAR-10.
    Conv1(64) → LIF → Pool → Conv2(128) → LIF → Pool →
    Conv3(256) → LIF → Pool → FC(256) → LIF → Output(10)
    """
    def __init__(self, config, noise_strategy=None):
        super().__init__()
        self.num_steps = config['num_steps']
        self.threshold = 1.0
        self.noise_strategy = noise_strategy or NoNoise()

        c1 = config['conv1_filters']
        c2 = config['conv2_filters']
        c3 = config['conv3_filters']
        ks = config['kernel_size']
        pad = ks // 2
        hidden = config['hidden_size']

        # Conv layers
        self.conv1 = nn.Conv2d(config['input_channels'], c1, ks, padding=pad)
        self.bn1 = nn.BatchNorm2d(c1)
        self.pool1 = nn.AvgPool2d(2)

        self.conv2 = nn.Conv2d(c1, c2, ks, padding=pad)
        self.bn2 = nn.BatchNorm2d(c2)
        self.pool2 = nn.AvgPool2d(2)

        self.conv3 = nn.Conv2d(c2, c3, ks, padding=pad)
        self.bn3 = nn.BatchNorm2d(c3)
        self.pool3 = nn.AvgPool2d(2)

        # After 3 pools on 32×32: 4×4 × c3
        flat_size = c3 * 4 * 4

        self.fc = nn.Linear(flat_size, hidden)
        self.bn_fc = nn.BatchNorm1d(hidden)
        self.fc_out = nn.Linear(hidden, config['output_size'])

        # LIF parameters per layer
        self.beta1 = nn.Parameter(torch.ones(c1, 1, 1) * 0.9)
        self.beta2 = nn.Parameter(torch.ones(c2, 1, 1) * 0.9)
        self.beta3 = nn.Parameter(torch.ones(c3, 1, 1) * 0.9)
        self.beta_fc = nn.Parameter(torch.ones(hidden) * 0.9)

        # Learned noise parameters (only used if strategy is LearnedNoise)
        if isinstance(noise_strategy, LearnedNoise):
            init_val = math.log(noise_strategy.init_std)
            self.noise_log_std1 = nn.Parameter(torch.tensor(init_val))
            self.noise_log_std2 = nn.Parameter(torch.tensor(init_val))
            self.noise_log_std3 = nn.Parameter(torch.tensor(init_val))
            self.noise_log_std_fc = nn.Parameter(torch.tensor(init_val))

        self.dropout = nn.Dropout(0.1)

    def _get_noise(self, membrane, bn_layer, layer_idx=0):
        """Get noise for this layer based on the strategy."""
        if isinstance(self.noise_strategy, LearnedNoise):
            if not self.training:
                return 0
            log_stds = [self.noise_log_std1, self.noise_log_std2,
                        self.noise_log_std3, self.noise_log_std_fc]
            noise_std = torch.clamp(torch.exp(log_stds[layer_idx]), min=0.01, max=2.0)
            return torch.randn_like(membrane) * noise_std
        else:
            return self.noise_strategy.get_noise(
                membrane, bn_layer=bn_layer,
                threshold=self.threshold, training=self.training)

    def _lif_step(self, membrane, current, beta, bn_layer, layer_idx):
        beta_sig = torch.sigmoid(beta)
        membrane = beta_sig * membrane + current
        noise = self._get_noise(membrane, bn_layer, layer_idx)
        if isinstance(noise, torch.Tensor):
            membrane = membrane + noise
        spikes = spike_fn(membrane - self.threshold)
        membrane = membrane * (1 - spikes)
        return membrane, spikes

    def get_learned_noise_stds(self):
        """Return learned noise stds if using LearnedNoise strategy."""
        if isinstance(self.noise_strategy, LearnedNoise):
            return {
                'conv1': torch.clamp(torch.exp(self.noise_log_std1), min=0.01, max=2.0).item(),
                'conv2': torch.clamp(torch.exp(self.noise_log_std2), min=0.01, max=2.0).item(),
                'conv3': torch.clamp(torch.exp(self.noise_log_std3), min=0.01, max=2.0).item(),
                'fc': torch.clamp(torch.exp(self.noise_log_std_fc), min=0.01, max=2.0).item(),
            }
        return None

    def forward(self, x):
        batch_size = x.size(0)
        device = x.device

        # Precompute conv features (input is static across timesteps)
        c1_out = self.bn1(self.conv1(x))

        # Init membranes
        p1_shape = self.pool1(c1_out).shape
        mem1 = torch.zeros_like(c1_out)
        mem2 = torch.zeros(batch_size, self.conv2.out_channels,
                           p1_shape[2], p1_shape[3], device=device)
        p2_h, p2_w = p1_shape[2] // 2, p1_shape[3] // 2
        mem3 = torch.zeros(batch_size, self.conv3.out_channels,
                           p2_h, p2_w, device=device)
        mem_fc = torch.zeros(batch_size, self.fc.out_features, device=device)

        output_sum = torch.zeros(batch_size, self.fc_out.out_features, device=device)
        total_spikes = 0
        total_neurons = 0

        for t in range(self.num_steps):
            # Conv1 LIF
            mem1, spk1 = self._lif_step(mem1, c1_out, self.beta1, self.bn1, 0)
            spk1 = self.dropout(spk1)
            p1 = self.pool1(spk1)

            # Conv2 LIF
            c2_out = self.bn2(self.conv2(p1))
            mem2, spk2 = self._lif_step(mem2, c2_out, self.beta2, self.bn2, 1)
            spk2 = self.dropout(spk2)
            p2 = self.pool2(spk2)

            # Conv3 LIF
            c3_out = self.bn3(self.conv3(p2))
            mem3, spk3 = self._lif_step(mem3, c3_out, self.beta3, self.bn3, 2)
            spk3 = self.dropout(spk3)
            p3 = self.pool3(spk3)

            # FC LIF
            flat = p3.view(batch_size, -1)
            fc_out = self.bn_fc(self.fc(flat))
            mem_fc, spk_fc = self._lif_step(mem_fc, fc_out, self.beta_fc, self.bn_fc, 3)
            spk_fc = self.dropout(spk_fc)

            output_sum += self.fc_out(spk_fc)
            total_spikes += (spk1.sum() + spk2.sum() + spk3.sum() + spk_fc.sum()).item()
            total_neurons += spk1.numel() + spk2.numel() + spk3.numel() + spk_fc.numel()

        output = output_sum / self.num_steps
        activation = total_spikes / total_neurons if total_neurons > 0 else 0

        return output, activation


"""
BN Warmup Disambiguation Test — CIFAR-10
==========================================
Tests whether Signal noise wins because of signal-relative scaling
or because BN running_var creates an implicit noise warmup schedule.

Conditions (all α=0.6, the best value from prior experiment):
  A) Signal, no warmup      — already run: 73.1% (reference)
  B) Signal, 5-epoch warmup — no noise for 5 epochs, then signal-relative
  C) Fixed, 5-epoch warmup  — no noise for 5 epochs, then fixed at 0.6
  D) Fixed, no warmup       — already run: 67.5% (reference)

If A ≈ B >> C: signal-relative principle is doing the work
If A >> B ≈ C: implicit warmup schedule was the key
If A > B > C:  both contribute

~20 minutes on T4.
"""

import torch
import torch.nn as nn
import torch.nn.functional as F
from torch.utils.data import DataLoader
from torchvision import datasets, transforms
import numpy as np
import math

CONFIG = {
    'input_channels': 3,
    'output_size': 10,
    'batch_size': 128,
    'epochs': 40,
    'lr': 1e-3,
    'conv1_filters': 64,
    'conv2_filters': 128,
    'conv3_filters': 256,
    'kernel_size': 3,
    'hidden_size': 256,
    'num_steps': 20,
    'warmup_epochs': 5,
    'device': 'cuda' if torch.cuda.is_available() else 'cpu'
}

print(f"Device: {CONFIG['device']}")

# ============================================================
# SURROGATE GRADIENT
# ============================================================

class SurrogateSpike(torch.autograd.Function):
    scale = 25.0
    @staticmethod
    def forward(ctx, membrane):
        spikes = (membrane > 0).float()
        ctx.save_for_backward(membrane)
        return spikes
    @staticmethod
    def backward(ctx, grad_output):
        membrane, = ctx.saved_tensors
        sigmoid = torch.sigmoid(SurrogateSpike.scale * membrane)
        return grad_output * sigmoid * (1 - sigmoid) * SurrogateSpike.scale

spike_fn = SurrogateSpike.apply

# ============================================================
# CONV-SNN WITH WARMUP SUPPORT
# ============================================================

class ConvSNN(nn.Module):
    def __init__(self, config, noise_mode='none', alpha=0.6):
        """
        noise_mode: 'none', 'fixed', 'signal'
        alpha: noise strength (0.6 for both fixed and signal)
        """
        super().__init__()
        self.num_steps = config['num_steps']
        self.threshold = 1.0
        self.noise_mode = noise_mode
        self.alpha = alpha
        self.noise_enabled = (noise_mode != 'none')  # can be toggled for warmup

        c1 = config['conv1_filters']
        c2 = config['conv2_filters']
        c3 = config['conv3_filters']
        ks = config['kernel_size']
        pad = ks // 2
        hidden = config['hidden_size']

        self.conv1 = nn.Conv2d(config['input_channels'], c1, ks, padding=pad)
        self.bn1 = nn.BatchNorm2d(c1)
        self.pool1 = nn.AvgPool2d(2)

        self.conv2 = nn.Conv2d(c1, c2, ks, padding=pad)
        self.bn2 = nn.BatchNorm2d(c2)
        self.pool2 = nn.AvgPool2d(2)

        self.conv3 = nn.Conv2d(c2, c3, ks, padding=pad)
        self.bn3 = nn.BatchNorm2d(c3)
        self.pool3 = nn.AvgPool2d(2)

        flat_size = c3 * 4 * 4
        self.fc = nn.Linear(flat_size, hidden)
        self.bn_fc = nn.BatchNorm1d(hidden)
        self.fc_out = nn.Linear(hidden, config['output_size'])

        self.beta1 = nn.Parameter(torch.ones(c1, 1, 1) * 0.9)
        self.beta2 = nn.Parameter(torch.ones(c2, 1, 1) * 0.9)
        self.beta3 = nn.Parameter(torch.ones(c3, 1, 1) * 0.9)
        self.beta_fc = nn.Parameter(torch.ones(hidden) * 0.9)

        self.dropout = nn.Dropout(0.1)

    def _get_noise(self, membrane, bn_layer):
        if not self.training or not self.noise_enabled:
            return 0

        if self.noise_mode == 'fixed':
            return torch.randn_like(membrane) * self.alpha

        elif self.noise_mode == 'signal':
            signal_std = torch.sqrt(bn_layer.running_var + 1e-5)
            shape = [1] * membrane.dim()
            shape[1] = -1
            signal_std = signal_std.view(*shape)
            return torch.randn_like(membrane) * (self.alpha * signal_std)

        return 0

    def _lif_step(self, membrane, current, beta, bn_layer):
        beta_sig = torch.sigmoid(beta)
        membrane = beta_sig * membrane + current
        noise = self._get_noise(membrane, bn_layer)
        if isinstance(noise, torch.Tensor):
            membrane = membrane + noise
        spikes = spike_fn(membrane - self.threshold)
        membrane = membrane * (1 - spikes)
        return membrane, spikes

    def forward(self, x):
        batch_size = x.size(0)
        device = x.device

        c1_out = self.bn1(self.conv1(x))
        p1_shape = self.pool1(c1_out).shape

        mem1 = torch.zeros_like(c1_out)
        mem2 = torch.zeros(batch_size, self.conv2.out_channels,
                           p1_shape[2], p1_shape[3], device=device)
        p2_h, p2_w = p1_shape[2] // 2, p1_shape[3] // 2
        mem3 = torch.zeros(batch_size, self.conv3.out_channels,
                           p2_h, p2_w, device=device)
        mem_fc = torch.zeros(batch_size, self.fc.out_features, device=device)

        output_sum = torch.zeros(batch_size, self.fc_out.out_features, device=device)
        total_spikes = 0
        total_neurons = 0

        for t in range(self.num_steps):
            mem1, spk1 = self._lif_step(mem1, c1_out, self.beta1, self.bn1)
            spk1 = self.dropout(spk1)
            p1 = self.pool1(spk1)

            c2_out = self.bn2(self.conv2(p1))
            mem2, spk2 = self._lif_step(mem2, c2_out, self.beta2, self.bn2)
            spk2 = self.dropout(spk2)
            p2 = self.pool2(spk2)

            c3_out = self.bn3(self.conv3(p2))
            mem3, spk3 = self._lif_step(mem3, c3_out, self.beta3, self.bn3)
            spk3 = self.dropout(spk3)
            p3 = self.pool3(spk3)

            flat = p3.view(batch_size, -1)
            fc_out = self.bn_fc(self.fc(flat))
            mem_fc, spk_fc = self._lif_step(mem_fc, fc_out, self.beta_fc, self.bn_fc)
            spk_fc = self.dropout(spk_fc)

            output_sum += self.fc_out(spk_fc)
            total_spikes += (spk1.sum() + spk2.sum() + spk3.sum() + spk_fc.sum()).item()
            total_neurons += spk1.numel() + spk2.numel() + spk3.numel() + spk_fc.numel()

        output = output_sum / self.num_steps
        activation = total_spikes / total_neurons if total_neurons > 0 else 0
        return output, activation

# ============================================================
# DATA
# ============================================================

def load_data(config):
    train_transform = transforms.Compose([
        transforms.RandomCrop(32, padding=4),
        transforms.RandomHorizontalFlip(),
        transforms.ToTensor(),
        transforms.Normalize((0.4914, 0.4822, 0.4465), (0.2470, 0.2435, 0.2616))
    ])
    test_transform = transforms.Compose([
        transforms.ToTensor(),
        transforms.Normalize((0.4914, 0.4822, 0.4465), (0.2470, 0.2435, 0.2616))
    ])
    train_data = datasets.CIFAR10('./data', train=True, download=True,
                                   transform=train_transform)
    test_data = datasets.CIFAR10('./data', train=False, download=True,
                                  transform=test_transform)
    pin = config['device'] == 'cuda'
    workers = 2 if pin else 0
    train_loader = DataLoader(train_data, batch_size=config['batch_size'],
                              shuffle=True, num_workers=workers, pin_memory=pin)
    test_loader = DataLoader(test_data, batch_size=config['batch_size'],
                             shuffle=False, num_workers=workers, pin_memory=pin)
    return train_loader, test_loader

# ============================================================
# TRAINING WITH WARMUP
# ============================================================

def train_and_eval(model, train_loader, test_loader, config, name,
                   warmup_epochs=0):
    optimizer = torch.optim.Adam(model.parameters(), lr=config['lr'])
    scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, config['epochs'])
    criterion = nn.CrossEntropyLoss()
    device = config['device']
    model = model.to(device)

    best_acc = 0
    print(f"\n  {name}:")

    for epoch in range(config['epochs']):
        # Toggle noise based on warmup
        if warmup_epochs > 0 and epoch < warmup_epochs:
            model.noise_enabled = False
            warmup_status = " [BN warmup — noise OFF]"
        else:
            model.noise_enabled = (model.noise_mode != 'none')
            warmup_status = ""

        model.train()
        correct = 0
        total = 0
        total_loss = 0

        for data, target in train_loader:
            data, target = data.to(device), target.to(device)
            optimizer.zero_grad()
            output, _ = model(data)
            loss = criterion(output, target)
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
            optimizer.step()
            total_loss += loss.item()
            _, predicted = output.max(1)
            correct += predicted.eq(target).sum().item()
            total += target.size(0)

        scheduler.step()
        train_acc = 100. * correct / total

        # Eval
        model.eval()
        test_correct = 0
        test_total = 0
        total_act = 0
        n_batches = 0

        with torch.no_grad():
            for data, target in test_loader:
                data, target = data.to(device), target.to(device)
                output, act = model(data)
                total_act += act
                n_batches += 1
                _, predicted = output.max(1)
                test_correct += predicted.eq(target).sum().item()
                test_total += target.size(0)

        test_acc = 100. * test_correct / test_total
        if test_acc > best_acc:
            best_acc = test_acc

        if (epoch + 1) % 5 == 0 or epoch == 0 or epoch == warmup_epochs:
            print(f"    Epoch {epoch+1}/{config['epochs']}: "
                  f"Train={train_acc:.1f}%, Test={test_acc:.1f}%, "
                  f"Act={total_act/n_batches:.3f}{warmup_status}")

    return {
        'accuracy': test_acc / 100,
        'best_accuracy': best_acc / 100,
        'activation_rate': total_act / n_batches,
    }

# ============================================================
# MAIN
# ============================================================

def run_experiment():
    config = CONFIG
    warmup = config['warmup_epochs']

    print("=" * 65)
    print("BN WARMUP DISAMBIGUATION TEST — CIFAR-10")
    print(f"All conditions: α=0.6, {config['epochs']} epochs, "
          f"warmup={warmup} epochs where applicable")
    print("=" * 65)

    print("\n[1] Loading CIFAR-10...")
    train_loader, test_loader = load_data(config)

    results = {}

    # A) Signal, no warmup (replicates prior result)
    print("\n[A] Signal(α=0.6), no warmup")
    torch.manual_seed(42)
    model_a = ConvSNN(config, noise_mode='signal', alpha=0.6)
    results['Signal, no warmup'] = train_and_eval(
        model_a, train_loader, test_loader, config,
        name="Signal(0.6), no warmup", warmup_epochs=0)

    # B) Signal, 5-epoch warmup
    print(f"\n[B] Signal(α=0.6), {warmup}-epoch warmup")
    torch.manual_seed(42)
    model_b = ConvSNN(config, noise_mode='signal', alpha=0.6)
    results['Signal, warmup'] = train_and_eval(
        model_b, train_loader, test_loader, config,
        name=f"Signal(0.6), {warmup}ep warmup", warmup_epochs=warmup)

    # C) Fixed, 5-epoch warmup
    print(f"\n[C] Fixed(0.6), {warmup}-epoch warmup")
    torch.manual_seed(42)
    model_c = ConvSNN(config, noise_mode='fixed', alpha=0.6)
    results['Fixed, warmup'] = train_and_eval(
        model_c, train_loader, test_loader, config,
        name=f"Fixed(0.6), {warmup}ep warmup", warmup_epochs=warmup)

    # D) Fixed, no warmup (replicates prior result)
    print("\n[D] Fixed(0.6), no warmup")
    torch.manual_seed(42)
    model_d = ConvSNN(config, noise_mode='fixed', alpha=0.6)
    results['Fixed, no warmup'] = train_and_eval(
        model_d, train_loader, test_loader, config,
        name="Fixed(0.6), no warmup", warmup_epochs=0)

    # ============================================================
    # RESULTS
    # ============================================================
    print(f"\n{'='*65}")
    print("RESULTS")
    print(f"{'='*65}")

    print(f"\n  {'Condition':<30} {'Test Acc':>8} {'Best Acc':>8} {'Act':>6}")
    print(f"  {'-'*55}")

    for name, r in results.items():
        print(f"  {name:<30} {r['accuracy']*100:>7.1f}% "
              f"{r['best_accuracy']*100:>7.1f}% {r['activation_rate']:>5.3f}")

    # ============================================================
    # INTERPRETATION
    # ============================================================
    print(f"\n{'='*65}")
    print("INTERPRETATION")
    print(f"{'='*65}")

    a = results['Signal, no warmup']['accuracy']
    b = results['Signal, warmup']['accuracy']
    c = results['Fixed, warmup']['accuracy']
    d = results['Fixed, no warmup']['accuracy']

    signal_warmup_effect = (b - a) * 100
    fixed_warmup_effect = (c - d) * 100
    signal_vs_fixed_no_warmup = (a - d) * 100
    signal_vs_fixed_with_warmup = (b - c) * 100

    print(f"""
  Signal gap (no warmup vs warmup):     {signal_warmup_effect:+.1f}%
  Fixed gap (no warmup vs warmup):      {fixed_warmup_effect:+.1f}%
  Signal vs Fixed (no warmup):          {signal_vs_fixed_no_warmup:+.1f}%
  Signal vs Fixed (with warmup):        {signal_vs_fixed_with_warmup:+.1f}%
    """)

    # Decision logic
    signal_principle_holds = signal_vs_fixed_with_warmup > 2.0
    warmup_is_significant = abs(signal_warmup_effect) > 2.0

    if signal_principle_holds and not warmup_is_significant:
        verdict = ("SIGNAL-RELATIVE PRINCIPLE CONFIRMED.\n"
                   "  Signal beats Fixed with and without warmup by similar margin.\n"
                   "  The BN warmup schedule is NOT the explanation.")
    elif not signal_principle_holds and warmup_is_significant:
        verdict = ("WARMUP SCHEDULE IS THE KEY.\n"
                   "  Signal's advantage disappears when both have warmup.\n"
                   "  The implicit noise schedule was doing the work.")
    elif signal_principle_holds and warmup_is_significant:
        verdict = ("BOTH CONTRIBUTE.\n"
                   "  Signal-relative scaling helps AND warmup helps.\n"
                   "  The full benefit is the combination.")
    else:
        verdict = ("INCONCLUSIVE.\n"
                   "  Effects are small (<2%). Need more epochs or seeds.")

    print(f"  VERDICT: {verdict}")

    # Prior results for reference
    print(f"\n  Same architecture and data as prior CIFAR-10 experiment.")
    print(f"  Results directly comparable to:")
    print(f"    Signal(0.6), no warmup:  73.1%")
    print(f"    Fixed(0.6), no warmup:   67.5%")
    print(f"    Signal advantage:        +5.6%")
    print(f"    Control (no noise):      11.7%")


if __name__ == '__main__':
    run_experiment()
